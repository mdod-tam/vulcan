<div class="<%= local_assigns.fetch(:card_class) %>">
  <div class="px-4 py-5 sm:p-6">
    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4" id="complete-training-heading">
      Mark Training as Completed
    </h3>

    <%= form_with(
      url: complete_trainers_training_session_path(training_session),
      method: :post,
      local: true,
      class: "space-y-4",
      aria: { labelledby: "complete-training-heading" },
      data: {
        controller: "training-duration-confirmation",
        action: "submit->training-duration-confirmation#confirm"
      }
    ) do |f| %>
      <div>
        <%= f.label :product_trained_on_id, class: "block text-sm font-medium text-gray-700" do %>
          Product Trained On <span class="text-red-600">*</span><span class="sr-only"> (required)</span>
        <% end %>
        <%= f.collection_select :product_trained_on_id, Product.all.order(:name), :id, :name, { prompt: "Select a product" }, { class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md", required: true, aria: { required: "true" } } %>
      </div>

      <div>
        <%= f.label :duration_hours, class: "block text-sm font-medium text-gray-700" do %>
          Training Duration <span class="text-red-600">*</span><span class="sr-only"> (required)</span>
        <% end %>
        <%= f.number_field :duration_hours,
                           value: training_session.duration_hours || 2.0,
                           min: 0.25,
                           step: 0.25,
                           required: true,
                           class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm",
                           aria: { required: "true", describedby: "duration_hours_hint" },
                           data: { training_duration_confirmation_target: "duration" } %>
        <p class="mt-1 text-sm text-gray-500" id="duration_hours_hint">Enter total time spent training, in hours.</p>
      </div>

      <div>
        <%= f.label :notes, class: "block text-sm font-medium text-gray-700" do %>
          Training Notes <span class="text-red-600">*</span><span class="sr-only"> (required)</span>
        <% end %>
        <%= f.text_area :notes, rows: 4, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", required: true, placeholder: "Enter details about what was covered...", aria: { required: "true", describedby: "complete_notes_hint" } %>
        <p class="mt-1 text-sm text-gray-500" id="complete_notes_hint">Internal note only. It is not included in constituent communications.</p>
      </div>

      <dialog class="rounded-lg bg-white p-0 shadow-xl backdrop:bg-gray-500 backdrop:bg-opacity-75" aria-labelledby="training-duration-confirmation-title" aria-describedby="training-duration-confirmation-message" data-training-duration-confirmation-target="dialog" data-action="cancel->training-duration-confirmation#cancel">
        <div class="max-w-md p-6">
          <h4 id="training-duration-confirmation-title" class="text-lg font-semibold text-gray-900">Confirm training duration</h4>
          <p id="training-duration-confirmation-message" class="mt-3 text-sm text-gray-700" data-training-duration-confirmation-target="message"></p>
          <div class="mt-6 flex justify-end gap-3">
            <button type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" data-training-duration-confirmation-target="noButton" data-action="training-duration-confirmation#cancel">
              No
            </button>
            <button type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" data-training-duration-confirmation-target="yesButton" data-action="training-duration-confirmation#proceed">
              Yes
            </button>
          </div>
        </div>
      </dialog>

      <%= f.submit "Mark as Completed", class: "w-full inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
    <% end %>
  </div>
</div>
