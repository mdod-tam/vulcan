<div class="bg-white shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4" id="schedule-additional-heading">
      <%= t('trainers.training_sessions.actions.schedule_additional.title') %>
    </h3>

    <%= form_with(url: schedule_additional_trainers_training_session_path(training_session), method: :post, local: true, class: "space-y-4", aria: { labelledby: "schedule-additional-heading" }) do |f| %>
      <div>
        <%= f.label :scheduled_for, class: "block text-sm font-medium text-gray-700" do %>
          <%= t('trainers.training_sessions.actions.schedule_additional.scheduled_for_label') %> <span class="text-red-600">*</span><span class="sr-only"> <%= t('trainers.training_sessions.actions.required') %></span>
        <% end %>
        <%= f.datetime_local_field :scheduled_for, value: 1.week.from_now.strftime('%Y-%m-%dT%H:%M'), class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", required: true, aria: { required: "true" } %>
      </div>

      <div>
        <%= f.label :location, t('trainers.training_sessions.actions.schedule_additional.location_label'), class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :location, value: training_session.location, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: t('trainers.training_sessions.actions.schedule_additional.location_placeholder') %>
      </div>

      <div>
        <%= f.label :notes, t('trainers.training_sessions.actions.schedule_additional.notes_label'), class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_area :notes, rows: 3, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: t('trainers.training_sessions.actions.schedule_additional.notes_placeholder') %>
      </div>

      <%= f.submit t('trainers.training_sessions.actions.schedule_additional.submit'), class: "w-full inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    <% end %>
  </div>
</div>
