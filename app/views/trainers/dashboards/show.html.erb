<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:p-2 focus:bg-indigo-600 focus:text-white focus:z-50 focus:rounded">
  Skip to main content
</a>
<main id="main-content" class="container mx-auto px-4 py-8" role="main" aria-labelledby="trainer-dashboard-title" tabindex="-1">
  <div class="flex justify-between items-center mb-6">
    <h1 id="trainer-dashboard-title" class="text-2xl font-bold">Training Dashboard</h1>
    <div>
      <%= link_to admin_applications_path,
          class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500",
          aria: { label: "Return to applications dashboard" } do %>
        Back to Dashboard
      <% end %>
    </div>
  </div>

  <section aria-labelledby="trainer-summary-heading" class="mb-8">
    <h2 id="trainer-summary-heading" class="sr-only">Session summary</h2>
    <ul class="grid grid-cols-1 md:grid-cols-4 gap-6" role="list">
      <li class="bg-white shadow rounded-lg p-5">
        <h3 id="card-needs-scheduling" class="text-lg font-semibold text-gray-700 mb-3">Needs Scheduling</h3>
        <p class="text-3xl font-bold text-purple-600"><%= @needs_scheduling_count %><span class="sr-only"> items needing scheduling</span></p>
        <p class="text-sm text-gray-500 mt-1">
          <% if current_user.admin? %>
            Requests and assigned sessions awaiting scheduling
          <% else %>
            Assigned sessions awaiting scheduling
          <% end %>
        </p>
        <div class="mt-3">
          <%= link_to "View All", "#needs-scheduling-section",
              class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md font-medium text-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 min-h-[44px]",
              aria: { label: "View all training items needing scheduling" } %>
        </div>
      </li>

      <li class="bg-white shadow rounded-lg p-5">
        <h3 id="card-scheduled" class="text-lg font-semibold text-gray-700 mb-3">Scheduled Sessions</h3>
        <p class="text-3xl font-bold text-blue-600"><%= @scheduled_sessions.count %><span class="sr-only"> scheduled sessions</span></p>
        <p class="text-sm text-gray-500 mt-1">
          <% if current_user.admin? %>
            <%= @my_scheduled_sessions_count %> assigned to you
          <% else %>
            Upcoming training sessions
          <% end %>
        </p>
        <% if current_user.admin? %>
          <div class="mt-3 flex flex-wrap gap-2">
            <%= link_to "All Scheduled", trainers_dashboard_path(filter: "scheduled"),
                class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md font-medium text-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 min-h-[44px]",
                aria: { label: "View all scheduled sessions" } %>
            <%= link_to "My Scheduled", filtered_trainers_training_sessions_path(scope: "mine", status: "scheduled"),
                class: "inline-flex items-center px-4 py-2 border border-blue-300 bg-white hover:bg-blue-50 text-blue-700 rounded-md font-medium text-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 min-h-[44px]",
                aria: { label: "View scheduled sessions assigned to me" } %>
          </div>
        <% else %>
          <div class="mt-3">
            <%= link_to "View All", trainers_dashboard_path(filter: "scheduled"),
                class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md font-medium text-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 min-h-[44px]",
                aria: { label: "View all scheduled sessions" } %>
          </div>
        <% end %>
      </li>

      <li class="bg-white shadow rounded-lg p-5">
        <h3 id="card-completed" class="text-lg font-semibold text-gray-700 mb-3">Completed Sessions</h3>
        <p class="text-3xl font-bold text-green-700"><%= @completed_sessions.count %><span class="sr-only"> completed sessions</span></p>
        <p class="text-sm text-gray-500 mt-1">Training sessions completed</p>
        <div class="mt-3">
          <%= link_to "View All", trainers_dashboard_path(filter: "completed"),
              class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md font-medium text-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 min-h-[44px]",
              aria: { label: "View all completed sessions" } %>
        </div>
      </li>

      <li class="bg-white shadow rounded-lg p-5">
        <h3 id="card-followup" class="text-lg font-semibold text-gray-700 mb-3">Needs Follow-up</h3>
        <p class="text-3xl font-bold text-yellow-700"><%= @followup_sessions_count %><span class="sr-only"> sessions needing follow-up</span></p>
        <p class="text-sm text-gray-500 mt-1">Cancellations and no-shows</p>
        <div class="mt-3">
          <%= link_to "View All", trainers_dashboard_path(filter: "needs_followup"),
              class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md font-medium text-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 min-h-[44px]",
              aria: { label: "View all sessions needing follow-up" } %>
        </div>
      </li>
    </ul>
  </section>

  <% unless @current_filter.present? %>
    <!-- Assigned Sessions Awaiting Scheduling -->
    <div id="needs-scheduling-section" class="bg-white shadow rounded-lg p-6 mb-8">
      <div class="flex justify-between items-center mb-4">
        <h2 id="needs-scheduling-table-heading" class="text-xl font-semibold">Needs Scheduling</h2>
        <%= link_to "View All", requested_trainers_training_sessions_path, class: "text-blue-600 hover:text-blue-800",
            aria: { label: "View all sessions needing scheduling" } %>
      </div>

      <% if @pending_training_requests.any? || @requested_sessions_display.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200" aria-labelledby="needs-scheduling-table-heading">
            <thead class="bg-gray-50">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Constituent</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @pending_training_requests.each do |application| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= application.training_requested_at.strftime("%B %d, %Y") %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= application.constituent_full_name %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">
                      Awaiting Assignment
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <%= link_to "Visit App And Assign Trainer", admin_application_path(application), class: "bg-indigo-600 hover:bg-indigo-700 text-white py-1 px-3 rounded-md inline-block transition-colors duration-200" %>
                  </td>
                </tr>
              <% end %>
              <% @requested_sessions_display.each do |session| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= session.created_at.strftime("%B %d, %Y") %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= session.application.constituent_full_name %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-purple-100 text-purple-800">
                      Assigned, Needs Scheduling
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <%= link_to "View/Schedule", trainers_training_session_path(session), class: "bg-indigo-600 hover:bg-indigo-700 text-white py-1 px-3 rounded-md inline-block transition-colors duration-200" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-gray-500 text-center py-4">No sessions currently awaiting scheduling.</p>
      <% end %>
    </div>

    <% if current_user.admin? %>
      <!-- Admin's own scheduled training sessions -->
      <div class="bg-white shadow rounded-lg p-6 mb-8">
        <div class="flex justify-between items-center mb-4">
          <h2 id="my-upcoming-sessions-table-heading" class="text-xl font-semibold">My Upcoming Training Sessions</h2>
          <%= link_to "View My Scheduled", filtered_trainers_training_sessions_path(scope: "mine", status: "scheduled"), class: "text-blue-600 hover:text-blue-800",
              aria: { label: "View all scheduled sessions assigned to me" } %>
        </div>

        <% if @my_scheduled_sessions_display.any? %>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200" aria-labelledby="my-upcoming-sessions-table-heading">
              <thead class="bg-gray-50">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date/Time</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Constituent</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% @my_scheduled_sessions_display.each do |session| %>
                  <tr>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                      <%= session.scheduled_for.strftime("%B %d, %Y at %I:%M %p") %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                      <%= session.application.constituent_full_name %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                        <span class="sr-only">Status: </span><%= session.status.titleize %>
                      </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                      <%= link_to "View Details", trainers_training_session_path(session),
                          class: "bg-indigo-600 hover:bg-indigo-700 text-white py-1 px-3 rounded-md inline-block transition-colors duration-200",
                          aria: { label: "View details for #{session.application.constituent_full_name}" } %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="text-gray-500 text-center py-4">No upcoming training sessions are assigned to you.</p>
        <% end %>
      </div>
    <% end %>

    <!-- Upcoming Training Sessions -->
    <div class="bg-white shadow rounded-lg p-6 mb-8">
      <div class="flex justify-between items-center mb-4">
        <h2 id="upcoming-sessions-table-heading" class="text-xl font-semibold">Upcoming Training Sessions</h2>
        <%= link_to "View All", scheduled_trainers_training_sessions_path, class: "text-blue-600 hover:text-blue-800",
            aria: { label: "View all upcoming scheduled sessions" } %>
      </div>

      <% if @upcoming_sessions_display.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200" aria-labelledby="upcoming-sessions-table-heading">
            <thead class="bg-gray-50">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date/Time</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Constituent</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @upcoming_sessions_display.each do |session| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= session.scheduled_for.strftime("%B %d, %Y at %I:%M %p") %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= session.application.constituent_full_name %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                      <span class="sr-only">Status: </span><%= session.status.titleize %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <%= link_to "View Details", trainers_training_session_path(session),
                        class: "bg-indigo-600 hover:bg-indigo-700 text-white py-1 px-3 rounded-md inline-block transition-colors duration-200",
                        aria: { label: "View details for #{session.application.constituent_full_name}" } %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-gray-500 text-center py-4">No upcoming training sessions scheduled.</p>
      <% end %>
    </div>
  <% end %>

  <% if @current_filter.present? && @filtered_sessions.present? %>
    <!-- Filtered Results -->
    <div class="bg-white shadow rounded-lg p-6 mb-8">
      <div class="flex justify-between items-center mb-4">
        <h2 id="filtered-sessions-table-heading" class="text-xl font-semibold"><%= @section_title %></h2>
        <%= link_to "Clear Filter", trainers_dashboard_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      </div>

      <% if @filtered_sessions.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200" aria-labelledby="filtered-sessions-table-heading">
            <thead class="bg-gray-50">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                  <% if @current_filter == 'scheduled' %>Date/Time<% else %>Date<% end %>
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Constituent</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @filtered_sessions.each do |session| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <% if @current_filter == 'scheduled' && session.scheduled_for.present? %>
                      <%= session.scheduled_for.strftime("%B %d, %Y at %I:%M %p") %>
                    <% elsif @current_filter == 'completed' && session.completed_at.present? %>
                      <%= session.completed_at.strftime("%B %d, %Y") %>
                    <% else %>
                      <%= session.created_at.strftime("%B %d, %Y") %>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= session.application.constituent_full_name %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% status_color = case session.status
                                     when 'requested' then 'bg-purple-100 text-purple-800'
                                     when 'scheduled', 'confirmed' then 'bg-blue-100 text-blue-800'
                                     when 'completed' then 'bg-green-100 text-green-800'
                                     when 'cancelled', 'no_show' then 'bg-yellow-100 text-yellow-800'
                                     else 'bg-gray-100 text-gray-800'
                                     end %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= status_color %>">
                      <span class="sr-only">Status: </span><%= session.status.titleize %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <%= link_to "View Details", trainers_training_session_path(session),
                        class: "bg-indigo-600 hover:bg-indigo-700 text-white py-1 px-3 rounded-md inline-block transition-colors duration-200",
                        aria: { label: "View details for #{session.application.constituent_full_name}" } %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-gray-500 text-center py-4">No training sessions found.</p>
      <% end %>
    </div>
  <% end %>

  <!-- Recent Training Sessions Needing Follow-up -->
  <% unless @current_filter.present? %>
    <div class="bg-white shadow rounded-lg p-6 mb-8">
      <div class="flex justify-between items-center mb-4">
      <h2 id="followup-sessions-table-heading" class="text-xl font-semibold">Recent Training Sessions Needing Follow-up</h2>
      <%= link_to "View All", trainers_dashboard_path(filter: "needs_followup"), class: "text-blue-600 hover:text-blue-800",
          aria: { label: "View all sessions needing follow-up" } %>
      </div>

      <% if @recent_followup_sessions.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200" aria-labelledby="followup-sessions-table-heading">
            <thead class="bg-gray-50">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Constituent</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @recent_followup_sessions.each do |session| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= session.updated_at&.strftime("%B %d, %Y") || "N/A" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= session.application.constituent_full_name %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% status_color = case session.status
                                     when 'cancelled' then 'bg-yellow-100 text-yellow-800'
                                     when 'no_show' then 'bg-red-100 text-red-800'
                                     else 'bg-gray-100 text-gray-800'
                                     end %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= status_color %>">
                      <span class="sr-only">Status: </span><%= session.status.titleize %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <%= link_to "View Details", trainers_training_session_path(session),
                        class: "bg-indigo-600 hover:bg-indigo-700 text-white py-1 px-3 rounded-md inline-block transition-colors duration-200",
                        aria: { label: "View details for #{session.application.constituent_full_name}" } %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-gray-500 text-center py-4">No training sessions needing follow-up.</p>
      <% end %>
    </div>
  <% end %>

  <!-- Recent Activity -->
  <section aria-labelledby="recent-completed-heading" class="bg-white shadow rounded-lg p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 id="recent-completed-heading" class="text-xl font-semibold">Recent Completed Sessions</h2>
      <%= link_to "View All", completed_trainers_training_sessions_path, class: "text-blue-600 hover:text-blue-800",
          aria: { label: "View all completed sessions" } %>
    </div>

    <% if @recent_completed_sessions.any? %>
      <ul class="space-y-4" role="list">
        <% @recent_completed_sessions.each do |session| %>
          <li class="border-b border-gray-200 pb-4 last:border-0 last:pb-0">
            <div class="flex justify-between items-start">
              <div>
                <p class="font-medium"><%= session.application.constituent_full_name %></p>
                <p class="text-sm text-gray-500">
                  Completed: <%= session.completed_at&.strftime("%B %d, %Y") || "Unknown" %>
                </p>
              </div>
              <%= link_to "View Details", trainers_training_session_path(session),
                  class: "bg-indigo-600 hover:bg-indigo-700 text-white py-1 px-3 rounded-md inline-block transition-colors duration-200",
                  aria: { label: "View details for #{session.application.constituent_full_name}" } %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-gray-500 text-center py-4">No completed training sessions yet.</p>
    <% end %>
  </section>

  <div class="mt-8">
    <%= render "shared/activity_history", activity_logs: @activity_logs, title: "Recent Activity", show_subject: true %>
  </div>
</main>
