<% content_for :title, t('.title') %>
<% errors = @form_errors %>

<section aria-labelledby="secure-provider-info-title" class="rounded-md border border-gray-200 bg-white p-6 shadow-sm">
  <h1 id="secure-provider-info-title" class="text-2xl font-semibold text-gray-900"><%= t('.heading') %></h1>
  <p class="mt-3 text-sm text-gray-700">
    <% if @constituent_name_available %>
      <%= t('.intro', constituent_name: @constituent_name) %>
    <% else %>
      <%= t('.intro_without_name') %>
    <% end %>
  </p>

  <% if errors&.any? %>
    <div class="mt-6 rounded-md border border-red-300 bg-red-50 p-4 focus:outline-none focus:ring-2 focus:ring-red-700"
         role="alert"
         aria-labelledby="error-summary-title"
         tabindex="-1"
         data-controller="error-summary">
      <h2 id="error-summary-title" class="text-base font-semibold text-red-900"><%= t('.error_summary') %></h2>
      <ul class="mt-2 list-disc pl-5 text-sm text-red-800">
        <% errors.each do |error| %>
          <% field_label = secure_provider_info_field_label(error.attribute) %>
          <li>
            <a class="underline focus:outline-none focus:ring-2 focus:ring-red-700"
               href="#<%= error.attribute %>"
               data-action="click->error-summary#focus">
              <% if field_label.present? %><strong class="font-semibold"><%= field_label %>:</strong> <% end %><%= error.message %>
            </a>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @form_error_message.present? %>
    <div class="mt-6 rounded-md border border-red-300 bg-red-50 p-4 text-sm text-red-800" role="alert">
      <%= @form_error_message %>
    </div>
  <% end %>

  <%= form_with url: secure_provider_info_form_path(token: @token), method: :patch, local: true, class: "mt-6 space-y-5" do |form| %>
    <%= hidden_field_tag :token, @token %>
    <p class="text-sm text-gray-600"><%= t('.required_legend') %></p>

    <%# Explicit id: values match the error summary anchor hrefs (#medical_provider_name, etc.).
        Without the override, form_with would prefix them with the model name. %>
    <% name_errors = Array(errors&.[](:medical_provider_name)) %>
    <div>
      <%= form.label :medical_provider_name, class: "block text-sm font-medium text-gray-900" do %>
        <%= t('.provider_name') %> <abbr title="<%= t('.required') %>" class="text-red-700 no-underline" aria-hidden="true">*</abbr>
      <% end %>
      <%= form.text_field :medical_provider_name,
                          id: "medical_provider_name",
                          required: true,
                          value: params[:medical_provider_name],
                          autocomplete: "off",
                          aria: {
                            describedby: name_errors.any? ? "medical_provider_name_error" : nil,
                            invalid: name_errors.any? ? "true" : nil
                          },
                          class: "mt-2 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-600 focus:ring-indigo-600 #{'border-red-500' if name_errors.any?}" %>
      <% if name_errors.any? %>
        <p id="medical_provider_name_error" class="mt-2 text-sm text-red-700"><%= name_errors.to_sentence %></p>
      <% end %>
    </div>

    <% email_errors = Array(errors&.[](:medical_provider_email)) %>
    <div>
      <%= form.label :medical_provider_email, class: "block text-sm font-medium text-gray-900" do %>
        <%= t('.provider_email') %> <abbr title="<%= t('.required') %>" class="text-red-700 no-underline" aria-hidden="true">*</abbr>
      <% end %>
      <%= form.email_field :medical_provider_email,
                           id: "medical_provider_email",
                           required: true,
                           value: params[:medical_provider_email],
                           autocomplete: "email",
                           aria: {
                             describedby: email_errors.any? ? "medical_provider_email_error" : nil,
                             invalid: email_errors.any? ? "true" : nil
                           },
                           class: "mt-2 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-600 focus:ring-indigo-600 #{'border-red-500' if email_errors.any?}" %>
      <% if email_errors.any? %>
        <p id="medical_provider_email_error" class="mt-2 text-sm text-red-700"><%= email_errors.to_sentence %></p>
      <% end %>
    </div>

    <% phone_errors = Array(errors&.[](:medical_provider_phone)) %>
    <div>
      <%= form.label :medical_provider_phone, class: "block text-sm font-medium text-gray-900" do %>
        <%= t('.provider_phone') %> <abbr title="<%= t('.required') %>" class="text-red-700 no-underline" aria-hidden="true">*</abbr>
      <% end %>
      <%= form.telephone_field :medical_provider_phone,
                               id: "medical_provider_phone",
                               required: true,
                               value: params[:medical_provider_phone],
                               autocomplete: "tel",
                               aria: {
                                 describedby: phone_errors.any? ? "medical_provider_phone_error" : nil,
                                 invalid: phone_errors.any? ? "true" : nil
                               },
                               class: "mt-2 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-600 focus:ring-indigo-600 #{'border-red-500' if phone_errors.any?}" %>
      <% if phone_errors.any? %>
        <p id="medical_provider_phone_error" class="mt-2 text-sm text-red-700"><%= phone_errors.to_sentence %></p>
      <% end %>
    </div>

    <% fax_errors = Array(errors&.[](:medical_provider_fax)) %>
    <div>
      <%= form.label :medical_provider_fax, t('.provider_fax'), class: "block text-sm font-medium text-gray-900" %>
      <%= form.telephone_field :medical_provider_fax,
                               id: "medical_provider_fax",
                               value: params[:medical_provider_fax],
                               autocomplete: "tel",
                               aria: {
                                 describedby: fax_errors.any? ? "medical_provider_fax_error" : nil,
                                 invalid: fax_errors.any? ? "true" : nil
                               },
                               class: "mt-2 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-600 focus:ring-indigo-600 #{'border-red-500' if fax_errors.any?}" %>
      <% if fax_errors.any? %>
        <p id="medical_provider_fax_error" class="mt-2 text-sm text-red-700"><%= fax_errors.to_sentence %></p>
      <% end %>
    </div>

    <%= form.submit t('.submit'),
                    data: { turbo_submits_with: t('.submitting') },
                    class: "inline-flex w-full justify-center rounded-md bg-indigo-700 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-600 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 sm:w-auto" %>
  <% end %>
</section>
