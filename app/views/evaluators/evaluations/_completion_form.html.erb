<div class="bg-white shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">
      Mark Evaluation as Completed
    </h3>

    <%= form_with(model: evaluation, url: evaluators_evaluation_path(evaluation), method: :patch, local: true, class: "space-y-4") do |f| %>
      <%= f.hidden_field :status, value: 'completed' %>

      <div>
        <%= f.label :location, class: "block text-sm font-medium text-gray-700" do %>
          Location <span class="text-red-600">*</span><span class="sr-only"> (required)</span>
        <% end %>
        <%= f.text_field :location, value: evaluation.location, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", required: true %>
      </div>

      <div>
        <%= f.label :attendees_field, class: "block text-sm font-medium text-gray-700" do %>
          Other Attendees <span class="text-gray-500 font-normal">(optional)</span>
        <% end %>
        <%= f.text_field :attendees_field, value: evaluation.attendees_field, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: "e.g., family friend, interpreter, Jane Doe" %>
        <p class="mt-1 text-sm text-gray-500">If anyone else attended the session, list them here. Separate multiple attendees with commas.</p>
      </div>

      <fieldset>
        <legend class="block text-sm font-medium text-gray-700">Products Tried <span class="text-red-600">*</span><span class="sr-only"> (required)</span></legend>
        <div class="mt-2 space-y-2 max-h-48 overflow-y-auto border border-gray-300 rounded-md p-3 bg-white">
          <%= f.collection_check_boxes :products_tried_field, available_products, :id, :name, checked: evaluation.products_tried_field do |b| %>
            <div class="flex items-start">
              <div class="flex items-center h-5">
                <%= b.check_box class: "focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded" %>
              </div>
              <div class="ml-3 text-sm">
                <%= b.label class: "font-medium text-gray-700" %>
              </div>
            </div>
          <% end %>
        </div>
      </fieldset>

      <fieldset>
        <legend class="block text-sm font-medium text-gray-700">Recommended Products <span class="text-red-600">*</span><span class="sr-only"> (required)</span></legend>
        <div class="mt-2 space-y-2 max-h-48 overflow-y-auto border border-gray-300 rounded-md p-3 bg-white">
          <%= f.collection_check_boxes :recommended_product_ids, available_products, :id, :name, checked: evaluation.recommended_product_ids do |b| %>
            <div class="flex items-start">
              <div class="flex items-center h-5">
                <%= b.check_box class: "focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded" %>
              </div>
              <div class="ml-3 text-sm">
                <%= b.label class: "font-medium text-gray-700" %>
              </div>
            </div>
          <% end %>
        </div>
      </fieldset>

      <div>
        <%= f.label :notes, class: "block text-sm font-medium text-gray-700" do %>
          Notes <span class="text-red-600">*</span><span class="sr-only"> (required)</span>
        <% end %>
        <%= f.text_area :notes, value: evaluation.notes, rows: 3, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: "Evaluation notes (including any specific constituent needs)...", required: true %>
      </div>

      <%= f.submit "Mark as Completed", class: "w-full inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
    <% end %>
  </div>
</div>
