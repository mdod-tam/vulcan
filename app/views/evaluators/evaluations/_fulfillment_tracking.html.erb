<div class="mt-8 bg-white shadow rounded-lg mb-6 border border-indigo-200">
  <div class="px-4 py-5 sm:p-6">
    <h3 class="text-lg leading-6 font-medium text-indigo-900 mb-4">
      Admin Fulfillment Tracking
    </h3>

    <%= form_with(model: evaluation.application, url: admin_application_equipment_fulfillment_path(evaluation.application), method: :patch, local: true, class: "space-y-4") do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= f.label :equipment_bids_sent_at, "Date Bids Sent", class: "block text-sm font-medium text-gray-700" %>
          <%= f.date_field :equipment_bids_sent_at, value: evaluation.application.equipment_bids_sent_at&.to_date, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
        </div>

        <div>
          <%= f.label :equipment_po_sent_at, "Date PO Sent", class: "block text-sm font-medium text-gray-700" %>
          <%= f.date_field :equipment_po_sent_at, value: evaluation.application.equipment_po_sent_at&.to_date, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
        </div>
      </div>

      <div class="mt-4">
        <%= f.submit "Update Fulfillment Dates", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      </div>
    <% end %>
  </div>
</div>
