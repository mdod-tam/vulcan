<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:p-2 focus:bg-indigo-600 focus:text-white focus:z-50 focus:rounded">
  <%= t('evaluators.evaluations.show.skip_to_main') %>
</a>

<div id="main-content" tabindex="-1" class="container mx-auto px-4 py-8">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6">
    <h1 class="text-2xl font-bold mb-2 sm:mb-0" id="page-heading"><%= t('evaluators.evaluations.show.title') %></h1>

    <div class="flex items-center space-x-4">
      <%= link_to t('evaluators.evaluations.show.back_to_evaluations'), evaluators_evaluations_path, class: "bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-2 px-4 rounded inline-flex items-center" %>
    </div>
  </div>

  <section aria-labelledby="evaluation-details-heading" class="bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6 flex justify-between items-center">
      <div>
        <h2 id="evaluation-details-heading" class="text-lg leading-6 font-medium text-gray-900">
          <%= t('evaluators.evaluations.show.evaluation_for', name: @evaluation.constituent.full_name) %>
        </h2>
        <p class="mt-1 max-w-2xl text-sm text-gray-500">
          <%= t('evaluators.evaluations.show.application_number', id: @evaluation.application_id) %>
        </p>
        <%= link_to t('evaluators.evaluations.show.view_full_application_details'),
                    admin_application_path(@evaluation.application),
                    class: "mt-1 inline-block text-sm text-indigo-600 hover:text-indigo-900" %>
      </div>

      <%= evaluation_status_badge(@evaluation) %>
    </div>

    <div class="border-t border-gray-200">
      <dl>
        <% if @evaluation.status_completed? %>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.completed_at') %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <% if @evaluation.evaluation_date.present? %>
                <time datetime="<%= @evaluation.evaluation_date.iso8601 %>">
                  <%= @evaluation.evaluation_date.strftime("%B %d, %Y at %I:%M %p") %>
                </time>
              <% else %>
                <%= t('evaluators.evaluations.show.unknown') %>
              <% end %>
            </dd>
          </div>
        <% elsif @evaluation.status_requested? && @evaluation.evaluation_date.blank? %>
          <div class="bg-blue-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-blue-900"><%= t('evaluators.evaluations.show.next_step') %></dt>
            <dd class="mt-1 text-sm text-blue-900 sm:mt-0 sm:col-span-2">
              <p class="font-semibold"><%= t('evaluators.evaluations.show.requested_next_step_title') %></p>
              <p class="mt-1">
                <% if @can_manage_evaluation %>
                  <%= t('evaluators.evaluations.show.requested_next_step_manage', evaluator: @evaluation.evaluator.full_name) %>
                <% else %>
                  <%= t('evaluators.evaluations.show.requested_next_step_read_only', evaluator: @evaluation.evaluator.full_name) %>
                <% end %>
              </p>
            </dd>
          </div>
        <% elsif !@evaluation.status_cancelled? && !@evaluation.status_no_show? %>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.scheduled_for') %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <% if @evaluation.evaluation_date.present? %>
                <time datetime="<%= @evaluation.evaluation_date.iso8601 %>">
                  <%= @evaluation.evaluation_date.strftime("%B %d, %Y at %I:%M %p") %>
                </time>
              <% else %>
                <%= t('evaluators.evaluations.show.not_scheduled') %>
              <% end %>
            </dd>
          </div>
        <% end %>

        <% if @evaluation.location.present? %>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.location') %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= @evaluation.location %>
            </dd>
          </div>
        <% end %>

        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.assigned_evaluator') %></dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <%= link_to @evaluation.evaluator.full_name,
                        evaluators_evaluations_path(scope: current_user.admin? ? "all" : "mine"),
                        class: "text-indigo-600 hover:text-indigo-900" %>
          </dd>
        </div>

        <% if @evaluation.notes.present? && @evaluation.status_completed? %>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.evaluator_notes') %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= simple_format(@evaluation.notes) %>
            </dd>
          </div>
        <% elsif @evaluation.notes.present? && @evaluation.status_cancelled? %>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.current_cancellation_reason') %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= simple_format(@evaluation.notes) %>
            </dd>
          </div>
        <% elsif @evaluation.notes.present? && @evaluation.status_no_show? %>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.current_no_show_notes') %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= simple_format(@evaluation.notes) %>
            </dd>
          </div>
        <% elsif @evaluation.notes.present? %>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.current_evaluator_notes') %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= simple_format(@evaluation.notes) %>
            </dd>
          </div>
        <% end %>

        <% if @evaluation.reschedule_reason.present? %>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.current_rescheduling_reason') %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= simple_format(@evaluation.reschedule_reason) %>
            </dd>
          </div>
        <% end %>

        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.constituent') %></dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <div>
              <p><%= @evaluation.constituent.full_name %></p>
              <p><%= link_to @evaluation.constituent.email, "mailto:#{@evaluation.constituent.email}", class: "text-indigo-600 hover:text-indigo-900", aria: { label: t('evaluators.evaluations.show.email_aria', email: @evaluation.constituent.email) } %></p>
              <p><%= link_to @evaluation.constituent.phone, "tel:#{@evaluation.constituent.phone}", class: "text-indigo-600 hover:text-indigo-900", aria: { label: t('evaluators.evaluations.show.call_aria', phone: @evaluation.constituent.phone) } %></p>
              <% if @evaluation.constituent.physical_address_1.present? %>
                <div class="mt-2 text-gray-600">
                  <p><%= @evaluation.constituent.physical_address_1 %></p>
                  <% if @evaluation.constituent.physical_address_2.present? %>
                    <p><%= @evaluation.constituent.physical_address_2 %></p>
                  <% end %>
                  <p><%= "#{@evaluation.constituent.city}, #{@evaluation.constituent.state} #{@evaluation.constituent.zip_code}" %></p>
                </div>
              <% end %>
            </div>
          </dd>
        </div>

        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.communication_preferences') %></dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <ul class="space-y-1">
              <li><strong><%= t('evaluators.evaluations.show.contact_method') %>:</strong> <%= contact_method_label(@evaluation.constituent.phone_type) %></li>
              <li><strong><%= t('evaluators.evaluations.show.preferred_language') %>:</strong> <%= language_label(@evaluation.constituent.locale) %></li>
              <li><strong><%= t('evaluators.evaluations.show.communication_modality') %>:</strong> <%= @evaluation.constituent.preferred_means_of_communication.presence || t('evaluators.evaluations.show.not_specified') %></li>
              <li><strong><%= t('evaluators.evaluations.show.delivery_preference') %>:</strong> <%= delivery_preference_label(@evaluation.constituent) %></li>
            </ul>
          </dd>
        </div>

        <% if @evaluation.constituent.disabilities.any? %>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.disabilities') %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <ul class="list-disc pl-5">
                <% @evaluation.constituent.disabilities.each do |disability| %>
                  <li><%= disability %></li>
                <% end %>
              </ul>
            </dd>
          </div>
        <% end %>

        <% if @evaluation.attendees.any? %>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.attendees') %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= safe_join(@evaluation.attendee_display_values, tag.br) %>
            </dd>
          </div>
        <% end %>

        <% if @evaluation.products_tried.any? %>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.products_tried') %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <ul class="list-disc pl-5">
                <% @evaluation.products_tried.each do |product| %>
                  <% product_name = Product.find_by(id: product['product_id'])&.name || t('evaluators.evaluations.show.unknown_product') %>
                  <li><%= "#{product_name} — #{product['reaction']}" %></li>
                <% end %>
              </ul>
            </dd>
          </div>
        <% end %>

        <% if @evaluation.recommended_products.any? %>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500"><%= t('evaluators.evaluations.show.recommended_products') %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <ul class="list-disc pl-5">
                <% @evaluation.recommended_products.each do |product| %>
                  <li><%= product.name %></li>
                <% end %>
              </ul>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>
  </section>

  <% if current_user.admin? && @evaluation.status_completed? && @evaluation.application.equipment_fulfillment? %>
    <%= render "fulfillment_tracking", evaluation: @evaluation %>
  <% end %>

  <section aria-label="<%= @can_manage_evaluation ? t('evaluators.evaluations.show.actions_label') : t('evaluators.evaluations.show.status_label') %>" class="mt-8" data-controller="evaluation-management">
    <% if @evaluation.errors.any? %>
      <div class="rounded-md bg-red-50 p-4 mb-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              <%= t('evaluators.evaluations.show.errors_heading',
                    count: @evaluation.errors.count,
                    error_count: pluralize(@evaluation.errors.count, t('evaluators.evaluations.show.error'))) %>
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul role="list" class="list-disc space-y-1 pl-5">
                <% @evaluation.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <% if !@can_manage_evaluation %>
      <div class="bg-slate-50 border border-slate-200 rounded-lg p-4 text-sm text-slate-700">
        <%= t('evaluators.evaluations.show.read_only_notice') %>
      </div>
    <% elsif @evaluation.status_requested? && @evaluation.evaluation_date.blank? %>
      <div class="space-y-6 mb-6">
        <%= render "schedule_form", evaluation: @evaluation %>
        <%= render "cancel_form", evaluation: @evaluation %>
      </div>
    <% elsif (@evaluation.status_scheduled? || @evaluation.status_confirmed?) && @evaluation.evaluation_date.present? && @evaluation.evaluation_date < Time.current %>
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 text-sm text-blue-900 mb-6">
        <p class="font-semibold"><%= t('evaluators.evaluations.show.outcome_due_title') %></p>
        <p class="mt-1"><%= t('evaluators.evaluations.show.outcome_due_body') %></p>
      </div>
      <div class="space-y-6 mb-6">
        <%= render "completion_form", evaluation: @evaluation, available_products: @available_products %>
        <%= render "no_show_form", evaluation: @evaluation %>
        <%= render "cancel_form", evaluation: @evaluation %>
        <%= render "reschedule_form",
            evaluation: @evaluation,
            suggested_date: @evaluation.evaluation_date %>
      </div>
    <% elsif @evaluation.status_scheduled? || @evaluation.status_confirmed? %>
      <div class="space-y-6 mb-6">
        <%= render "completion_form", evaluation: @evaluation, available_products: @available_products %>
        <%= render "cancel_form", evaluation: @evaluation %>
        <%= render "reschedule_form",
            evaluation: @evaluation,
            suggested_date: @evaluation.evaluation_date %>
      </div>
    <% elsif @evaluation.status_cancelled? || @evaluation.status_no_show? || @evaluation.status_rescheduled? %>
      <%= render "reschedule_form",
          evaluation: @evaluation,
          suggested_date: 1.week.from_now %>
    <% elsif @evaluation.status_completed? %>
      <%= render "completed_notes_form", evaluation: @evaluation %>
    <% else %>
      <div class="bg-slate-50 border border-slate-200 rounded-lg p-4 text-sm text-slate-700">
        <%= t('evaluators.evaluations.show.lifecycle_unavailable') %>
      </div>
    <% end %>
  </section>

  <div class="mt-8">
    <%= render "shared/activity_history", activity_logs: @activity_logs, title: t('evaluators.evaluations.show.activity_history') %>
  </div>
</div>
