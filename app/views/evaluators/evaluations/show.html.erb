<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Evaluation Details</h1>

    <div>
      <%= link_to "Back to Evaluations", evaluators_evaluations_path, class: "bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-2 px-4 rounded inline-flex items-center" %>
    </div>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6 flex justify-between items-center">
      <div>
        <h3 class="text-lg leading-6 font-medium text-gray-900">
          Evaluation for <%= @evaluation.constituent.full_name %>
        </h3>
        <p class="mt-1 max-w-2xl text-sm text-gray-500">
          Application #<%= @evaluation.application_id %>
        </p>
      </div>

      <!-- Status badge with color coding -->
      <% status_classes = case @evaluation.status
         when 'scheduled' then 'bg-blue-100 text-blue-800'
         when 'confirmed' then 'bg-green-100 text-green-800'
         when 'completed' then 'bg-purple-100 text-purple-800'
         when 'cancelled' then 'bg-yellow-100 text-yellow-800'
         when 'no_show' then 'bg-red-100 text-red-800'
         else 'bg-gray-100 text-gray-800'
         end %>

      <span class="px-3 py-1 inline-flex text-sm leading-5 font-semibold rounded-full <%= status_classes %>">
        <%= @evaluation.status.titleize %>
      </span>
    </div>

    <div class="border-t border-gray-200">
      <dl>
        <% if @evaluation.status_completed? %>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Completed At</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= @evaluation.evaluation_date&.strftime("%B %d, %Y at %I:%M %p") || "Unknown" %>
            </dd>
          </div>
        <% elsif !@evaluation.status_cancelled? && !@evaluation.status_no_show? %>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Scheduled For</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= @evaluation.evaluation_date&.strftime("%B %d, %Y at %I:%M %p") || "Not scheduled" %>
            </dd>
          </div>
        <% end %>

        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Constituent</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <div>
              <p><%= @evaluation.constituent.full_name %></p>
              <p><a href="mailto:<%= @evaluation.constituent.email %>" class="text-indigo-600 hover:text-indigo-900"><%= @evaluation.constituent.email %></a></p>
              <p><a href="tel:<%= @evaluation.constituent.phone %>" class="text-indigo-600 hover:text-indigo-900"><%= @evaluation.constituent.phone %></a></p>
              <% if @evaluation.constituent.physical_address_1.present? %>
                <div class="mt-2 text-gray-600">
                  <p><%= @evaluation.constituent.physical_address_1 %></p>
                  <% if @evaluation.constituent.physical_address_2.present? %>
                    <p><%= @evaluation.constituent.physical_address_2 %></p>
                  <% end %>
                  <p><%= "#{@evaluation.constituent.city}, #{@evaluation.constituent.state} #{@evaluation.constituent.zip_code}" %></p>
                </div>
              <% end %>
            </div>
          </dd>
        </div>

        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Communication Preferences</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <ul class="space-y-1">
              <li><strong>Contact Method:</strong> <%= contact_method_label(@evaluation.constituent.phone_type) %></li>
              <li><strong>Preferred Language:</strong> <%= language_label(@evaluation.constituent.locale) %></li>
              <li><strong>Communication Modality:</strong> <%= @evaluation.constituent.preferred_means_of_communication.presence || "Not specified" %></li>
            </ul>
          </dd>
        </div>

        <% if @evaluation.location.present? %>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Location</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= @evaluation.location %>
            </dd>
          </div>
        <% end %>

        <% if @evaluation.constituent.disabilities.any? %>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Disabilities</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <ul class="list-disc pl-5">
                <% @evaluation.constituent.disabilities.each do |disability| %>
                  <li><%= disability %></li>
                <% end %>
              </ul>
            </dd>
          </div>
        <% end %>

        <% if @evaluation.notes.present? %>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Evaluator Notes</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= simple_format(@evaluation.notes) %>
            </dd>
          </div>
        <% end %>

        <% if @evaluation.attendees.any? %>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Attendees</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <ul class="list-disc pl-5">
                <% @evaluation.attendees.each do |attendee| %>
                  <li><%= "#{attendee['name']} - #{attendee['relationship']}" %></li>
                <% end %>
              </ul>
            </dd>
          </div>
        <% end %>

        <% if @evaluation.products_tried.any? %>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Products Tried</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <ul class="list-disc pl-5">
                <% @evaluation.products_tried.each do |product| %>
                  <% product_name = Product.find_by(id: product['product_id'])&.name || 'Unknown product' %>
                  <li><%= "#{product_name} — #{product['reaction']}" %></li>
                <% end %>
              </ul>
            </dd>
          </div>
        <% end %>

        <% if @evaluation.recommended_products.any? %>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Recommended Products</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <ul class="list-disc pl-5">
                <% @evaluation.recommended_products.each do |product| %>
                  <li><%= product.name %></li>
                <% end %>
              </ul>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>

  <% if current_user.admin? && @evaluation.status_completed? && @evaluation.application.equipment_fulfillment? %>
    <%= render "fulfillment_tracking", evaluation: @evaluation %>
  <% end %>

  <!-- Form sections for managing evaluation - Start -->
  <div class="mt-8" data-controller="evaluation-management">
    <% if @evaluation.errors.any? %>
      <div class="rounded-md bg-red-50 p-4 mb-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              <%= pluralize(@evaluation.errors.count, "error") %> prohibited this evaluation from being saved:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul role="list" class="list-disc space-y-1 pl-5">
                <% @evaluation.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <% if !@can_manage_evaluation %>
      <div class="bg-slate-50 border border-slate-200 rounded-lg p-4 text-sm text-slate-700">
        This is a read-only oversight view. Only the assigned evaluator can update this evaluation.
      </div>
    <% elsif @evaluation.evaluation_date.blank? %>
      <%= render "schedule_form", evaluation: @evaluation %>
    <% elsif (@evaluation.status_scheduled? || @evaluation.status_confirmed?) && @evaluation.evaluation_date.present? && @evaluation.evaluation_date < Time.current %>
      <div class="space-y-6 mb-6">
        <%= render "completion_form", evaluation: @evaluation, available_products: @available_products %>
        <%= render "no_show_form", evaluation: @evaluation %>
      </div>

    <% elsif @evaluation.status_scheduled? || @evaluation.status_confirmed? %>
      <%= render "cancel_form", evaluation: @evaluation %>
      <%= render "reschedule_form",
          evaluation: @evaluation,
          suggested_date: @evaluation.evaluation_date %>

    <% elsif @evaluation.status_cancelled? || @evaluation.status_no_show? %>
      <%= render "reschedule_form",
          evaluation: @evaluation,
          suggested_date: 1.week.from_now %>
    <% elsif @evaluation.status_completed? %>
      <%= render "completed_notes_form", evaluation: @evaluation %>
    <% else %>
      <%= render "reschedule_form",
          evaluation: @evaluation,
          suggested_date: 1.week.from_now %>
    <% end %>
  </div>
  <!-- Form sections for managing evaluation - End -->

  <div class="mt-8">
    <%= render "shared/activity_history", activity_logs: @activity_logs, title: "Activity History" %>
  </div>

  <!-- Link to view the full application -->
  <div class="mt-6 text-right">
    <%= link_to "View Full Application", admin_application_path(@evaluation.application), class: "text-indigo-600 hover:text-indigo-900" %>
  </div>
</div>
