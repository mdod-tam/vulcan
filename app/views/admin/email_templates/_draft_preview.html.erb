<%= turbo_frame_tag frame_id, aria: { live: "polite", atomic: "true" } do %>
  <div class="mt-6 mb-6 p-4 border border-gray-200 rounded-md bg-white">
    <div class="flex items-start justify-between gap-3 mb-3">
      <h3 class="text-lg font-medium text-gray-700">
        Draft Preview (<%= template.locale.to_s.upcase %>)
      </h3>
      <span class="<%= template_syntax_badge_classes(template) %>">
        <%= template_syntax_label(template) %>
      </span>
    </div>

    <% if error_message.present? %>
      <div class="rounded-md border border-red-300 bg-red-50 p-3 text-sm text-red-800" role="alert">
        <p><%= error_message %></p>
      </div>
    <% else %>
      <div role="status">
        <div class="mb-4">
          <h4 class="text-md font-medium text-gray-600 mb-2">
            Subject Preview: <span class="font-normal"><%= rendered_subject %></span>
          </h4>
        </div>

        <div class="prose max-w-none mb-4">
          <h4 class="text-md font-medium text-gray-600 mb-2">
            Body Preview
          </h4>

          <div class="border border-gray-300 rounded-lg shadow-sm p-4 bg-white">
            <% if template.format == 'html' %>
              <div class="email-preview">
                <%= raw rendered_body %>
              </div>
            <% else %>
              <pre class="whitespace-pre-wrap text-sm"><%= rendered_body %></pre>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <div class="text-sm text-gray-600 mt-2 italic">
      <p>Preview uses sample data and does not save changes.</p>
    </div>
  </div>
<% end %>
