<% current_locale = local_assigns[:locale].presence || email_template.locale %>
<% locale_code = current_locale.to_s.upcase %>
<% locale_suffix = locale_code.downcase %>
<% submit_label = local_assigns[:submit_label].presence || "Save #{locale_code}" %>
<% form_action_path = local_assigns[:form_action_path].presence || admin_email_template_path(email_template) %>
<% locale_field_id = "email-template-locale-#{locale_suffix}" %>
<% description_field_id = "email-template-description-#{locale_suffix}" %>
<% subject_field_id = "email-template-subject-#{locale_suffix}" %>
<% syntax_field_id = "email-template-syntax-#{locale_suffix}" %>
<% syntax_help_id = "syntax-help-#{locale_suffix}" %>
<% standard_help_id = "syntax-standard-help-#{locale_suffix}" %>
<% liquid_help_id = "syntax-liquid-help-#{locale_suffix}" %>
<% syntax_describedby = [syntax_help_id, standard_help_id, liquid_help_id].join(' ') %>
<% body_textarea_id = "email-template-body-#{locale_suffix}" %>
<% editor_field_id = "body-editor-#{locale_suffix}" %>
<% editor_label_id = "body-label-#{locale_suffix}" %>
<% editor_help_id = "body-help-#{locale_suffix}" %>
<% variable_help_id = "variable-help-#{locale_suffix}" %>
<% variable_select_id = "variable-insert-#{locale_suffix}" %>
<% subject_variable_select_id = "subject-variable-insert-#{locale_suffix}" %>
<% preview_frame_id = "template-preview-#{locale_suffix}" %>
<% required_vars = email_template.required_variables || [] %>
<% optional_vars = email_template.optional_variables || [] %>

<%= form_with(model: [:admin, email_template], url: form_action_path, method: :patch, class: "space-y-4", data: { controller: "protected-variables" }) do |form| %>
  <%= hidden_field_tag :locale, current_locale, id: locale_field_id %>

  <% if email_template.locale_needs_sync? %>
    <div class="rounded-md bg-amber-50 border border-amber-300 p-4" role="alert">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-amber-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3 flex-1 md:flex md:justify-between md:items-start">
          <p class="text-sm text-amber-800">
            <strong>Out of sync.</strong>
            Another locale variant of this template was updated. Update the body or subject below to resolve this.
          </p>
          <div class="mt-3 md:mt-0 md:ml-6 flex-shrink-0">
            <%= link_to "Mark Synced", mark_synced_admin_email_template_path(email_template),
                  data: { turbo_method: :patch, turbo_confirm: "Mark this template as synced without making changes?" },
                  class: "inline-flex items-center rounded-md border border-amber-400 bg-amber-100 px-3 py-1.5 text-sm font-medium text-amber-900 hover:bg-amber-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-600",
                  role: "button" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <% if email_template.errors.any? %>
    <div id="error_explanation_<%= locale_code.downcase %>" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative" role="alert">
      <strong class="font-bold">Please review.</strong>
      <span class="block sm:inline"><%= pluralize(email_template.errors.count, "error") %> prohibited this email_template from being saved:</span>
      <ul class="mt-3 list-disc list-inside text-sm">
        <% template_validation_error_messages(email_template.errors.full_messages).each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :description, "Template Purpose (#{locale_code})", for: description_field_id, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_area :description,
        rows: 2,
        id: description_field_id,
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
        placeholder: "Brief description of when this email is sent" %>
    <p class="mt-2 text-sm text-gray-500">
      Explain when and why this email is sent (e.g., "Sent when a constituent registers a new account").
    </p>
  </div>

  <div>
    <%= form.label :subject, "Email Subject (#{locale_code})", for: subject_field_id, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :subject,
        id: subject_field_id,
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
        data: { "protected-variables-target": "subjectInput" } %>
    <div class="mt-2 max-w-sm">
      <label for="<%= subject_variable_select_id %>" class="block text-sm font-medium text-gray-700 mb-2">
        Insert Variable in Subject
      </label>
      <select id="<%= subject_variable_select_id %>"
              class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:ring-1 text-sm"
              data-protected-variables-target="subjectVariableSelect">
        <option value="">-- Select a variable to insert --</option>
        <% if required_vars.any? %>
          <optgroup label="Required Variables">
            <% required_vars.each do |var| %>
              <option value="<%= variable_placeholder_for(email_template, var) %>"
                      data-variable-name="<%= var %>"
                      data-variable-kind="required"
                      data-legacy-placeholder="<%= variable_placeholder_for(email_template, var, syntax: :legacy_percent) %>"
                      data-liquid-placeholder="<%= variable_placeholder_for(email_template, var, syntax: :liquid) %>"
                      data-legacy-label="<%= variable_option_label(email_template, var, syntax: :legacy_percent) %>"
                      data-liquid-label="<%= variable_option_label(email_template, var, syntax: :liquid) %>"><%= variable_option_label(email_template, var) %></option>
            <% end %>
          </optgroup>
        <% end %>
        <% if optional_vars.any? %>
          <optgroup label="Optional (only if needed in message)">
            <% optional_vars.each do |var| %>
              <option value="<%= variable_placeholder_for(email_template, var) %>"
                      data-variable-name="<%= var %>"
                      data-variable-kind="optional"
                      data-legacy-placeholder="<%= variable_placeholder_for(email_template, var, syntax: :legacy_percent) %>"
                      data-liquid-placeholder="<%= variable_placeholder_for(email_template, var, syntax: :liquid) %>"
                      data-legacy-label="<%= variable_option_label(email_template, var, syntax: :legacy_percent) %>"
                      data-liquid-label="<%= variable_option_label(email_template, var, syntax: :liquid) %>"><%= variable_option_label(email_template, var) %></option>
            <% end %>
          </optgroup>
        <% end %>
      </select>
    </div>
  </div>

  <div>
    <%= form.label :syntax, "Placeholder Style (#{locale_code})", for: syntax_field_id, class: "block text-sm font-medium text-gray-700" %>
    <%= form.select :syntax,
        options_for_select(email_template_syntax_options(email_template), email_template.render_syntax),
        {},
        id: syntax_field_id,
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
        aria: { describedby: syntax_describedby },
        data: { "protected-variables-target": "syntaxSelect" } %>
    <div class="mt-2 space-y-2">
      <p id="<%= syntax_help_id %>" class="sr-only">
        Standard: most templates should stay Standard. Liquid: advanced exact-path variables for text templates. Liquid templates can only use Required Variables.
      </p>
      <p id="<%= standard_help_id %>"
         class="<%= standard_placeholder_style_help_classes(email_template) %>"
         data-protected-variables-target="standardHelp">
        Most templates should stay Standard. Use Insert Variable; do not type placeholders yourself.
      </p>
      <div id="<%= liquid_help_id %>"
           class="<%= liquid_placeholder_style_help_classes(email_template) %>"
           data-protected-variables-target="liquidHelp">
        <p>
          Liquid is an advanced placeholder style for templates that need exact-path variables. Use Insert Variable; do not type placeholders yourself.
        </p>
        <p class="mt-1 font-medium">
          Liquid templates can only use Required Variables. Optional choices are Standard-only.
        </p>
      </div>
    </div>
    <% if !email_template.text? %>
      <p class="mt-1 text-sm text-gray-500">Liquid is only available for text templates.</p>
    <% end %>
    <% if email_template.text? %>
      <div class="mt-3 hidden" data-protected-variables-target="convertPanel">
        <button type="button"
                class="inline-flex items-center rounded-md border border-cyan-300 bg-cyan-50 px-3 py-2 text-sm font-medium text-cyan-800 hover:bg-cyan-100"
                data-action="protected-variables#convertStandardPlaceholders">
          Convert Standard Placeholders
        </button>
        <p class="mt-1 text-sm text-gray-500">
          Replaces matching Standard placeholders in the subject and body with Liquid placeholders.
        </p>
      </div>
    <% end %>
  </div>

  <div>
    <%= form.label :body, "Body (#{locale_code})", id: editor_label_id, class: "block text-sm font-medium text-gray-700" %>
    
    <!-- Hidden textarea that stores actual data -->
    <%= form.text_area :body, 
        rows: 20, 
        id: body_textarea_id,
        class: "hidden",
        data: { "protected-variables-target": "textarea" } %>
    
    <!-- Visible editable div -->
    <div 
      id="<%= editor_field_id %>"
      data-protected-variables-target="editor"
      class="mt-1 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm font-mono p-3 min-h-96 bg-white"
      contenteditable="true"
      role="textbox"
      aria-multiline="true"
      tabindex="0"
      aria-labelledby="<%= editor_label_id %>"
      aria-describedby="<%= [editor_help_id, variable_help_id].join(' ') %>"
      style="white-space: pre-wrap; word-wrap: break-word; outline: none;">
    </div>
    
    <style>
      .protected-variable {
        background-color: #e0e7ff;
        color: #4f46e5;
        padding: 2px 4px;
        border-radius: 3px;
        font-weight: 500;
        cursor: not-allowed;
        user-select: none;
      }
    </style>
    
    <div class="mt-2 space-y-2">
      <div class="max-w-sm">
        <!-- Insert Variable Dropdown -->
        <label for="<%= variable_select_id %>" class="block text-sm font-medium text-gray-700 mb-2">
          Insert Variable into Body
        </label>
        <select id="<%= variable_select_id %>" class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:ring-1 text-sm" data-protected-variables-target="variableSelect">
        <option value="">-- Select a variable to insert --</option>
        <% if required_vars.any? %>
          <optgroup label="Required Variables">
            <% required_vars.each do |var| %>
              <option value="<%= variable_placeholder_for(email_template, var) %>"
                      data-variable-name="<%= var %>"
                      data-variable-kind="required"
                      data-legacy-placeholder="<%= variable_placeholder_for(email_template, var, syntax: :legacy_percent) %>"
                      data-liquid-placeholder="<%= variable_placeholder_for(email_template, var, syntax: :liquid) %>"
                      data-legacy-label="<%= variable_option_label(email_template, var, syntax: :legacy_percent) %>"
                      data-liquid-label="<%= variable_option_label(email_template, var, syntax: :liquid) %>"><%= variable_option_label(email_template, var) %></option>
            <% end %>
          </optgroup>
        <% end %>
        <% if optional_vars.any? %>
          <optgroup label="Optional (only if needed in message)">
            <% optional_vars.each do |var| %>
              <option value="<%= variable_placeholder_for(email_template, var) %>"
                      data-variable-name="<%= var %>"
                      data-variable-kind="optional"
                      data-legacy-placeholder="<%= variable_placeholder_for(email_template, var, syntax: :legacy_percent) %>"
                      data-liquid-placeholder="<%= variable_placeholder_for(email_template, var, syntax: :liquid) %>"
                      data-legacy-label="<%= variable_option_label(email_template, var, syntax: :legacy_percent) %>"
                      data-liquid-label="<%= variable_option_label(email_template, var, syntax: :liquid) %>"><%= variable_option_label(email_template, var) %></option>
            <% end %>
          </optgroup>
        <% end %>
      </select>
      </div>
      <!-- Variable Help text -->
      <div id="<%= variable_help_id %>" class="rounded-md border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-600">
        <p>Inserted body variables are highlighted and cannot be edited.</p>
        <p class="mt-1">Liquid disables optional choices because sends may omit them.</p>
      </div>
    </div>
    <p id="<%= editor_help_id %>" class="mt-2 text-sm text-gray-500">
      Edit message text in the body editor. Paste plain text when possible.
    </p>
  </div>

  <%
    begin
      sample_data = sample_data_for_email_template(email_template, locale: email_template.locale, subject: email_template.subject)
      rendered_subject, rendered_body = email_template.render(**sample_data)
      preview_error = nil
    rescue => e
      rendered_subject = nil
      rendered_body = nil
      preview_error = template_render_error_message(e)
    end
  %>
  <%= render 'admin/email_templates/draft_preview',
      frame_id: preview_frame_id,
      template: email_template,
      rendered_subject: rendered_subject,
      rendered_body: rendered_body,
      error_message: preview_error %>

  <div class="flex justify-end gap-3 pt-4">
    <%= form.submit "Preview Draft",
        formaction: preview_admin_email_template_path(email_template),
        class: "inline-flex justify-center py-2 px-4 border border-indigo-300 shadow-sm text-sm font-medium rounded-md text-indigo-700 bg-indigo-50 hover:bg-indigo-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500",
        data: { turbo_frame: preview_frame_id } %>
    <%= form.submit submit_label, class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
  </div>
<% end %>
