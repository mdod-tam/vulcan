<main class="container mx-auto px-4 py-8" role="main" aria-labelledby="edit-rejection-reason-title">
  <div class="max-w-4xl mx-auto">
    <%= render 'admin/shared/communications_section_nav', current: :rejection_reasons %>
    <div class="mb-6 flex items-start justify-between">
      <div>
        <h1 id="edit-rejection-reason-title" class="text-3xl font-bold text-gray-900">
          Edit Rejection Reason
        </h1>
        <p class="mt-2 text-sm text-gray-600">
          <span class="font-mono"><%= @rejection_reason.code %></span>
          for <%= rejection_reason_proof_type_label(@rejection_reason.proof_type) %> —
          <%= rejection_reason_locale_label(@rejection_reason.locale) %>
        </p>
      </div>
      <%= link_to 'Back to Rejection Reasons', admin_rejection_reasons_path,
          class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
    </div>

    <p class="text-sm text-gray-600 mb-4">
      Edit both locales below. Save EN and ES independently; if one changes, sync badges indicate which locale still needs review.
    </p>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
      <%# EN Panel %>
      <section class="bg-white rounded-lg shadow p-6 mb-6">
        <div class="flex items-start justify-between gap-4 mb-4">
          <div>
            <h2 class="text-lg font-semibold text-gray-900">
              Editing <%= rejection_reason_locale_label('en') %>
            </h2>
            <p class="text-sm text-gray-500"><%= rejection_reason_last_updated_text(@en_reason) %></p>
            <% if @en_reason %>
              <p class="text-sm text-gray-500 mt-1">Version: <%= @en_reason.version %></p>
            <% end %>
          </div>
          <% if @en_reason %>
            <span class="<%= rejection_reason_sync_badge_classes(@en_reason) %>">
              <%= rejection_reason_sync_status(@en_reason) %>
            </span>
          <% else %>
            <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700">
              Missing
            </span>
          <% end %>
        </div>

        <% if @en_reason %>
          <% if @en_reason.needs_sync? %>
            <div class="mb-4 rounded-md bg-amber-50 border border-amber-300 p-4">
              <p class="text-sm text-amber-800">
                This locale is out of sync with its counterpart.
                Update the body below, or
                <%= link_to 'mark it as synced', mark_synced_admin_rejection_reason_path(@en_reason),
                    data: { turbo_method: :patch, turbo_confirm: 'Mark this rejection reason as synced without changing text?' },
                    class: "font-medium underline hover:text-amber-700" %>.
              </p>
            </div>
          <% end %>

          <%= form_with model: [:admin, @en_reason], url: admin_rejection_reason_path(@en_reason, locale: 'en'), class: "space-y-4" do |form| %>
            <% if @en_reason.errors.any? %>
              <div class="rounded-md bg-red-50 border border-red-300 p-4">
                <p class="text-sm font-medium text-red-800">
                  <%= pluralize(@en_reason.errors.count, 'error') %> prevented this rejection reason from saving:
                </p>
                <ul class="mt-2 list-disc list-inside text-sm text-red-700">
                  <% @en_reason.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div>
              <%= form.label :body, "Reason Body (EN)", class: "block text-sm font-medium text-gray-700" %>
              <%= form.text_area :body, rows: 10,
                  class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
              <p class="mt-2 text-xs text-gray-500">
                Keep placeholders (like <span class="font-mono">%&lt;address&gt;s</span>) intact when required by downstream interpolation.
              </p>
            </div>

            <% if @en_reason.previous_body.present? %>
              <div class="rounded-md border border-gray-200 bg-gray-50 p-4">
                <p class="text-sm font-medium text-gray-700">Previous body</p>
                <pre class="mt-2 whitespace-pre-wrap text-sm text-gray-600"><%= @en_reason.previous_body %></pre>
              </div>
            <% end %>

            <div class="flex justify-end">
              <%= form.submit "Save EN",
                  class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
            </div>
          <% end %>
        <% else %>
          <div class="border border-gray-200 rounded-md p-4 bg-gray-50">
            <p class="text-sm text-gray-700 mb-3">
              The EN variant is missing for this rejection reason.
            </p>
          </div>
        <% end %>
      </section>

      <%# ES Panel %>
      <section class="bg-white rounded-lg shadow p-6 mb-6">
        <div class="flex items-start justify-between gap-4 mb-4">
          <div>
            <h2 class="text-lg font-semibold text-gray-900">
              Editing <%= rejection_reason_locale_label('es') %>
            </h2>
            <p class="text-sm text-gray-500"><%= rejection_reason_last_updated_text(@es_reason) %></p>
            <% if @es_reason %>
              <p class="text-sm text-gray-500 mt-1">Version: <%= @es_reason.version %></p>
            <% end %>
          </div>
          <% if @es_reason %>
            <span class="<%= rejection_reason_sync_badge_classes(@es_reason) %>">
              <%= rejection_reason_sync_status(@es_reason) %>
            </span>
          <% else %>
            <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700">
              Missing
            </span>
          <% end %>
        </div>

        <% if @es_reason %>
          <% if @es_reason.needs_sync? %>
            <div class="mb-4 rounded-md bg-amber-50 border border-amber-300 p-4">
              <p class="text-sm text-amber-800">
                This locale is out of sync with its counterpart.
                Update the body below, or
                <%= link_to 'mark it as synced', mark_synced_admin_rejection_reason_path(@es_reason),
                    data: { turbo_method: :patch, turbo_confirm: 'Mark this rejection reason as synced without changing text?' },
                    class: "font-medium underline hover:text-amber-700" %>.
              </p>
            </div>
          <% end %>

          <%= form_with model: [:admin, @es_reason], url: admin_rejection_reason_path(@es_reason, locale: 'es'), class: "space-y-4" do |form| %>
            <% if @es_reason.errors.any? %>
              <div class="rounded-md bg-red-50 border border-red-300 p-4">
                <p class="text-sm font-medium text-red-800">
                  <%= pluralize(@es_reason.errors.count, 'error') %> prevented this rejection reason from saving:
                </p>
                <ul class="mt-2 list-disc list-inside text-sm text-red-700">
                  <% @es_reason.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div>
              <%= form.label :body, "Reason Body (ES)", class: "block text-sm font-medium text-gray-700" %>
              <%= form.text_area :body, rows: 10,
                  class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
              <p class="mt-2 text-xs text-gray-500">
                Keep placeholders (like <span class="font-mono">%&lt;address&gt;s</span>) intact when required by downstream interpolation.
              </p>
            </div>

            <% if @es_reason.previous_body.present? %>
              <div class="rounded-md border border-gray-200 bg-gray-50 p-4">
                <p class="text-sm font-medium text-gray-700">Previous body</p>
                <pre class="mt-2 whitespace-pre-wrap text-sm text-gray-600"><%= @es_reason.previous_body %></pre>
              </div>
            <% end %>

            <div class="flex justify-end">
              <%= form.submit "Save ES",
                  class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
            </div>
          <% end %>
        <% else %>
          <div class="border border-gray-200 rounded-md p-4 bg-gray-50">
            <p class="text-sm text-gray-700 mb-3">
              The ES variant is missing for this rejection reason.
            </p>
          </div>
        <% end %>
      </section>
    </div>
  </div>
</main>
