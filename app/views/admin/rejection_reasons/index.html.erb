<main class="container mx-auto px-4 py-8" role="main" aria-labelledby="rejection-reasons-title">
  <div class="max-w-7xl mx-auto">
    <%= render 'admin/shared/communications_section_nav', current: :rejection_reasons %>

    <div class="mb-6">
      <h1 id="rejection-reasons-title" class="text-3xl font-bold text-gray-900">Rejection Reasons</h1>
      <p class="mt-2 text-sm text-gray-600">
        Review and edit DB-backed rejection reason text by proof type and locale.
      </p>
    </div>

    <section class="bg-white rounded-lg shadow mb-6" aria-labelledby="reason-groups-heading">
      <h2 id="reason-groups-heading" class="sr-only">Rejection reason groups</h2>

      <div class="overflow-x-auto">
        <% if @reason_groups.present? %>
          <div class="hidden md:block"> <%# Desktop version %>
            <table class="min-w-full table-fixed divide-y divide-gray-200" aria-label="Rejection reasons">
              <thead class="bg-gray-50">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-1/4">
                    Proof Type
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-1/4">
                    Code
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-20">
                    Locales
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-20">
                    Status
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-32">
                    Updated
                  </th>
                  <th scope="col" class="relative px-6 py-3 w-32">
                    <span class="sr-only">Actions</span>
                  </th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% @reason_groups.each do |group| %>
                  <% active_reason = group[:en] || group[:es] %>
                  <% next unless active_reason %>
                  <tr>
                    <td class="px-6 py-4 text-sm text-gray-600">
                      <%= rejection_reason_proof_type_label(group[:proof_type]) %>
                    </td>
                    <td class="px-6 py-4 text-sm font-mono text-gray-600 truncate">
                      <%= group[:code] %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                      <% if group[:en] %>
                        <span class="inline-flex items-center rounded-md bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800">EN</span>
                      <% end %>
                      <% if group[:es] %>
                        <span class="inline-flex items-center rounded-md bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800 ml-1">ES</span>
                      <% end %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                      <% if group[:en]&.needs_sync? || group[:es]&.needs_sync? %>
                        <span class="inline-flex items-center rounded-full bg-amber-100 px-3 py-1 text-xs font-medium text-amber-800">
                          Needs Sync
                        </span>
                      <% else %>
                        <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-800">
                          In sync
                        </span>
                      <% end %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                      <%= time_ago_in_words(active_reason.updated_at) %> ago
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
                      <%= link_to 'Edit', edit_admin_rejection_reason_path(active_reason), class: "text-indigo-600 hover:text-indigo-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-indigo-600" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <%# Mobile-friendly card layout %>
          <div class="md:hidden">
            <ul role="list" class="divide-y divide-gray-200 space-y-4">
              <% @reason_groups.each do |group| %>
                <% active_reason = group[:en] || group[:es] %>
                <% next unless active_reason %>
                <li class="p-6 sm:p-4 bg-white">
                  <div class="flex flex-col space-y-2">
                    <div class="flex items-center justify-between">
                      <h3 class="text-sm font-semibold text-gray-900">
                        <%= rejection_reason_proof_type_label(group[:proof_type]) %>
                      </h3>
                      <span class="text-xs font-mono text-gray-600"><%= group[:code] %></span>
                    </div>

                    <div class="flex justify-between items-center text-xs text-gray-600 mb-2">
                      <span>Locales: <%= [group[:en] ? 'EN' : nil, group[:es] ? 'ES' : nil].compact.join(', ') %> · Updated <%= time_ago_in_words(active_reason.updated_at) %> ago</span>
                      <% if group[:en]&.needs_sync? || group[:es]&.needs_sync? %>
                        <span class="inline-flex items-center rounded-full bg-amber-100 px-2 py-1 text-xs font-medium text-amber-800">
                          Needs Sync
                        </span>
                      <% else %>
                        <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-1 text-xs font-medium text-green-800">
                          In sync
                        </span>
                      <% end %>
                    </div>
                    <div class="flex justify-end items-center gap-2">
                      <%= link_to 'Edit', edit_admin_rejection_reason_path(active_reason), class: "text-indigo-600 hover:text-indigo-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-indigo-600 text-sm" %>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
        <% else %>
          <div class="p-6 text-center text-sm text-gray-600">
            No rejection reasons found. Run seeds to populate baseline records.
          </div>
        <% end %>
      </div>
    </section>
  </div>
</main>
