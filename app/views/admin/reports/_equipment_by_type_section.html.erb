<%# locals: (vouchers_enabled:, period:, period_options:, period_label:, rows:, chart_data:, error_message: nil) -%>
<% non_voucher_label = vouchers_enabled ? 'Without vouchers' : 'Equipment fulfilled' %>
<% voucher_label = 'With vouchers' %>

<section aria-labelledby="equipment-by-type-heading" class="bg-white rounded-lg shadow p-6 mb-8">
  <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between mb-4">
    <div>
      <h2 id="equipment-by-type-heading" class="text-xl font-bold">Equipment by Type</h2>
      <p class="text-sm text-gray-500 mt-1">
        <% if vouchers_enabled %>
          Equipment-fulfillment counts use applications with purchase orders sent.
          Voucher counts use completed voucher redemption products.
        <% else %>
          Equipment-fulfillment counts use applications with purchase orders sent.
        <% end %>
      </p>
    </div>
    <%= form_with url: admin_reports_path, method: :get, class: "flex items-center gap-2" do |f| %>
      <%= f.label :equipment_period, "Period:", class: "text-sm font-medium text-gray-700" %>
      <%= f.select :equipment_period,
          options_for_select(period_options.map { |value, label| [label, value] }, period),
          {},
          class: "rounded-md border-gray-300 shadow-sm focus:border-indigo-300 focus:ring focus:ring-indigo-200 focus:ring-opacity-50",
          onchange: "this.form.requestSubmit()" %>
    <% end %>
  </div>

  <div class="bg-gray-50 rounded p-4">
    <h3 id="equipment-period-heading" class="font-medium text-gray-700 mb-3"><%= period_label %></h3>
    <% if error_message.present? %>
      <div class="rounded-md border border-amber-200 bg-amber-50 p-4" role="alert">
        <p class="text-sm font-medium text-amber-900"><%= error_message %></p>
        <p class="mt-1 text-sm text-amber-800">Other report sections are still available.</p>
      </div>
    <% elsif rows.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-sm" aria-labelledby="equipment-period-heading">
          <caption class="sr-only">Equipment counts by device type for <%= period_label %></caption>
          <thead>
            <tr>
              <th scope="col" class="py-2 pr-3 text-left font-medium text-gray-700">Device type</th>
              <th scope="col" class="px-3 py-2 text-right font-medium text-gray-700">
                <%= non_voucher_label %>
              </th>
              <% if vouchers_enabled %>
                <th scope="col" class="py-2 pl-3 text-right font-medium text-gray-700">With vouchers</th>
              <% end %>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% rows.each do |row| %>
              <tr>
                <th scope="row" class="py-2 pr-3 text-left font-normal text-gray-600"><%= row[:device_type] %></th>
                <td class="px-3 py-2 text-right font-medium text-gray-900"><%= row[:non_voucher_count] %></td>
                <% if vouchers_enabled %>
                  <td class="py-2 pl-3 text-right font-medium text-gray-900"><%= row[:voucher_count] %></td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="mt-4" style="position: relative; height: 300px; width: 100%;"
           aria-describedby="equipment-by-type-chart-desc"
           data-controller="reports-chart"
           data-reports-chart-current-data-value="<%= chart_data[:non_voucher].to_json %>"
           data-reports-chart-previous-data-value="<%= (vouchers_enabled ? chart_data[:voucher] : {}).to_json %>"
           data-reports-chart-current-dataset-label-value="<%= non_voucher_label %>"
           data-reports-chart-previous-dataset-label-value="<%= vouchers_enabled ? voucher_label : '' %>"
           data-reports-chart-type-value="bar"
           data-reports-chart-title-value="Equipment by Type">
        <div id="equipment-by-type-chart-desc" class="sr-only">
          Bar chart showing equipment counts by device type for <%= period_label %>.
        </div>
      </div>
    <% else %>
      <p class="text-sm text-gray-500">No equipment recorded for this period.</p>
    <% end %>
  </div>
</section>
