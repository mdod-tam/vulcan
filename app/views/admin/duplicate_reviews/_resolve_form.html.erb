<%# locals: (review_case:, prefill: nil) -%>
<%
  prefill ||= {}
  reason_codes_prefill = prefill.key?(:reason_codes) ? Array(prefill[:reason_codes]) : nil
%>
<%= form_with url: resolve_admin_duplicate_review_path(review_case), method: :post, class: 'space-y-4',
              data: {
                controller: 'final-submit-gate',
                final_submit_gate_incomplete_message_value: 'Choose a review outcome and enter a rationale.',
                final_submit_gate_ready_message_value: 'Ready to save the review outcome.'
              } do |f| %>
  <fieldset aria-describedby="review-outcome-help" class="space-y-2">
    <legend class="text-sm font-medium text-gray-700">Review outcome</legend>
    <p id="review-outcome-help" class="text-xs text-gray-500">Choose one outcome. Terminal outcomes close the case; active outcomes keep it in the queue and pause merging.</p>
    <% duplicate_review_outcome_options.each do |option| %>
      <label class="flex items-start gap-2 rounded-md border border-gray-200 p-3 text-sm" for="resolve_outcome_<%= option[:value] %>">
        <%= radio_button_tag :outcome, option[:value], prefill[:outcome] == option[:value],
                              required: true, id: "resolve_outcome_#{option[:value]}", class: 'mt-1' %>
        <span>
          <span class="font-medium text-gray-900"><%= option[:label] %></span>
          <span class="ml-2 text-xs font-medium text-gray-500"><%= option[:kind] %></span>
          <span class="block text-xs text-gray-600"><%= option[:description] %></span>
        </span>
      </label>
    <% end %>
  </fieldset>

  <fieldset>
    <legend class="text-sm font-medium text-gray-700">Match signals</legend>
    <p class="text-xs text-gray-500 mb-1">These are the automated signals that flagged this pair — uncheck any that turned out not to matter. Unlike merge, at least one signal is not required here.</p>
    <% Array(review_case.metadata['reason_codes']).each do |code| %>
      <label class="inline-flex items-center mr-3 text-sm">
        <%= check_box_tag 'reason_codes[]', code, reason_codes_prefill ? reason_codes_prefill.include?(code) : true,
                          id: "resolve_reason_codes_#{code}" %>
        <span class="ml-1"><%= code.humanize %></span>
      </label>
    <% end %>
  </fieldset>

  <div>
    <%= label_tag 'resolve_rationale', 'Admin rationale (required)', class: 'block text-sm font-medium text-gray-700' %>
    <%= text_area_tag :rationale, prefill[:rationale], rows: 2, required: true, class: 'w-full border-gray-300 rounded-md text-sm',
                      placeholder: 'Explain the decision.', id: 'resolve_rationale' %>
  </div>

  <div>
    <p class="text-xs text-gray-500 mb-1" data-final-submit-gate-target="status" id="resolve_submit_gate_status" aria-live="polite"></p>
    <%= f.submit 'Save review outcome',
                 disabled: true,
                 class: 'bg-indigo-600 hover:bg-indigo-700 text-white py-2 px-4 rounded text-sm cursor-pointer ' \
                        'disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-indigo-600',
                 data: { final_submit_gate_target: 'submitButton' } %>
  </div>
<% end %>
