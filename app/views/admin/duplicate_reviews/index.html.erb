<div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8" data-testid="duplicate-review-queue">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold">Duplicate Review Queue</h1>
    <%= link_to 'Back to users', admin_users_path, class: 'text-indigo-600 hover:text-indigo-900 text-sm' %>
  </div>

  <section aria-labelledby="open-cases-heading" class="mb-10">
    <h2 id="open-cases-heading" class="text-lg font-medium text-gray-900 mb-3">Open cases</h2>

    <% if @open_cases.any? %>
      <div class="bg-white shadow overflow-hidden sm:rounded-md">
        <ul class="divide-y divide-gray-200">
          <% @open_cases.each do |review_case| %>
            <li class="px-4 py-4 sm:px-6" data-testid="duplicate-review-case-row">
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="text-base font-medium text-gray-900">
                    <%= review_case.subject_user&.full_name || 'Unattached subject' %>
                  </h3>
                  <p class="text-sm text-gray-500"><%= stored_email_display(review_case.subject_user) %> · <%= stored_phone_display(review_case.subject_user) %></p>
                  <div class="mt-1 flex flex-wrap gap-2 text-xs">
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-blue-100 text-blue-800" data-testid="case-source">
                      <%= duplicate_review_source_label(review_case.source) %>
                    </span>
                    <% Array(review_case.metadata['reason_codes']).each do |code| %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-gray-100 text-gray-700"><%= code.humanize %></span>
                    <% end %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-gray-100 text-gray-600">
                      <%= pluralize(review_case.duplicate_review_case_candidates.size, 'candidate') %>
                    </span>
                  </div>
                </div>
                <div class="text-sm text-right">
                  <div class="text-gray-500 mb-2">Opened <%= review_case.opened_at.strftime('%b %d, %Y') %></div>
                  <%= link_to 'Review', admin_duplicate_review_path(review_case), class: 'text-indigo-600 hover:text-indigo-900 font-medium' %>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% else %>
      <div class="bg-white shadow sm:rounded-md p-6 text-center text-gray-500">No open duplicate review cases.</div>
    <% end %>
  </section>

  <section aria-labelledby="legacy-heading">
    <h2 id="legacy-heading" class="text-lg font-medium text-gray-900 mb-3">Flagged records without a case (manual / legacy)</h2>

    <% if @legacy_flagged_users.any? %>
      <div class="bg-white shadow overflow-hidden sm:rounded-md">
        <ul class="divide-y divide-gray-200">
          <% @legacy_flagged_users.each do |user| %>
            <li class="px-4 py-4 sm:px-6" data-testid="legacy-flag-row">
              <div class="sm:flex sm:items-center sm:justify-between">
                <div>
                  <h3 class="text-base font-medium text-gray-900">
                    <%= link_to user.full_name, admin_user_path(user), class: 'hover:text-indigo-600' %>
                    <span class="ml-2 text-xs font-semibold text-yellow-800 bg-yellow-200 px-2 py-0.5 rounded-full">Manual / legacy flag</span>
                  </h3>
                  <p class="text-sm text-gray-500"><%= stored_email_display(user) %> · <%= stored_phone_display(user) %></p>
                </div>
                <%= form_with url: clear_flag_admin_duplicate_reviews_path, method: :post, class: 'mt-3 sm:mt-0 flex items-end gap-2' do |f| %>
                  <%= f.hidden_field :user_id, value: user.id %>
                  <div>
                    <%= f.label :rationale, 'Rationale', class: 'block text-xs text-gray-600' %>
                    <%= f.text_field :rationale, required: true, class: 'border-gray-300 rounded-md text-sm', placeholder: 'Why is this flag being cleared?' %>
                  </div>
                  <%= f.submit 'Clear flag', class: 'bg-gray-700 hover:bg-gray-800 text-white py-2 px-3 rounded text-xs cursor-pointer' %>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% else %>
      <div class="bg-white shadow sm:rounded-md p-6 text-center text-gray-500">No manual or legacy flags awaiting review.</div>
    <% end %>
  </section>
</div>
