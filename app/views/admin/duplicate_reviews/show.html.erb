<div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8" data-testid="duplicate-review-detail">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold">Duplicate Review Case #<%= @review_case.id %></h1>
    <%= link_to 'Back to queue', admin_duplicate_reviews_path, class: 'text-indigo-600 hover:text-indigo-900 text-sm' %>
  </div>

  <section class="bg-white shadow sm:rounded-md p-4 mb-6">
    <div class="flex flex-wrap gap-2 text-xs mb-2">
      <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-blue-100 text-blue-800"><%= duplicate_review_source_label(@review_case.source) %></span>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full <%= duplicate_review_status_badge_classes(@review_case.status) %>" data-testid="case-workflow-state"><%= duplicate_review_status_label(@review_case.status) %></span>
      <% Array(@review_case.metadata['reason_codes']).each do |code| %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-gray-100 text-gray-700"><%= code.humanize %></span>
      <% end %>
    </div>
    <p class="text-sm text-gray-600">Opened <%= @review_case.opened_at.strftime('%B %d, %Y at %I:%M %p') %></p>
    <% if @subject.nil? %>
      <p class="text-sm text-red-600 mt-2">The subject record is no longer attached to this case.</p>
    <% end %>
  </section>

  <% has_comparable_candidate = @candidates.any? { |c| c.candidate_user.present? && !c.candidate_user.merged? } %>

  <% if @subject %>
    <% unless has_comparable_candidate %>
      <section class="mb-8" aria-labelledby="subject-heading">
        <h2 id="subject-heading" class="text-lg font-medium text-gray-900 mb-3">Subject record</h2>
        <%= render 'record_facts', user: @subject, role_label: 'Subject' %>
      </section>
    <% end %>

    <section aria-labelledby="candidates-heading">
      <h2 id="candidates-heading" class="text-lg font-medium text-gray-900 mb-3">Candidate comparisons</h2>

      <% if @candidates.empty? %>
        <div class="bg-white shadow sm:rounded-md p-6 text-center text-gray-500">No candidate records were recorded for this case.</div>
      <% end %>

      <% @candidates.each do |candidate| %>
        <article class="bg-white shadow sm:rounded-md p-4 mb-6" data-testid="candidate-comparison">
          <div class="flex items-center gap-2 mb-3 text-xs">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-gray-100 text-gray-700"><%= candidate.match_reason.humanize %></span>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-gray-100 text-gray-600"><%= candidate_link_state_label(candidate) %></span>
          </div>

          <% if candidate.candidate_user.present? && !candidate.candidate_user.merged? %>
            <div class="mb-4">
              <%= render 'record_comparison', subject: @subject, candidate: candidate.candidate_user %>
            </div>
            <% if @review_case.merge_allowed? %>
              <% reopen = @merge_prefill && @merge_prefill[:candidate_id] == candidate.candidate_user.id %>
              <details class="border-t border-gray-100 pt-3"<%= ' open'.html_safe if reopen %>>
                <summary class="cursor-pointer text-sm font-medium text-red-700">Merge these two records</summary>
                <div class="mt-3">
                  <%= render 'merge_form', review_case: @review_case, subject: @subject, candidate: candidate.candidate_user,
                                           prefill: (reopen ? @merge_prefill : nil) %>
                </div>
              </details>
            <% elsif @review_case.nonterminal_hold? %>
              <p class="border-t border-gray-100 pt-3 text-sm text-amber-700" data-testid="merge-unavailable">
                Merge is unavailable while this case is <%= duplicate_review_status_label(@review_case.status).downcase %>. Return it to normal review before merging.
              </p>
            <% else %>
              <p class="border-t border-gray-100 pt-3 text-sm text-gray-500">This case is resolved. Merging is disabled.</p>
            <% end %>
          <% else %>
            <p class="text-sm text-gray-500">This candidate cannot be merged (record missing or already merged). Evidence snapshot is retained on the case.</p>
          <% end %>
        </article>
      <% end %>
    </section>
  <% end %>

  <% if @review_case.merge_allowed? %>
    <section class="bg-white shadow sm:rounded-md p-4 mt-8" aria-labelledby="resolve-heading">
      <h2 id="resolve-heading" class="text-lg font-medium text-gray-900 mb-3">Record review outcome</h2>
      <p class="text-sm text-gray-500 mb-4">Choose one terminal or active workflow outcome. This form never moves contact facts, applications, relationships, credentials, sessions, or delivery preferences.</p>
      <%= render 'resolve_form', review_case: @review_case, prefill: @resolve_prefill %>
    </section>
  <% elsif @review_case.nonterminal_hold? %>
    <section class="bg-white shadow sm:rounded-md p-4 mt-8" aria-labelledby="workflow-state-heading" data-testid="nonterminal-workflow-state">
      <h2 id="workflow-state-heading" class="text-lg font-medium text-gray-900 mb-3">Current review state</h2>
      <p class="text-sm text-gray-700 mb-2">
        This case is <strong><%= duplicate_review_status_label(@review_case.status).downcase %></strong>. It remains active and continues to own the duplicate-review flag.
      </p>
      <% if @review_case.security_review? %>
        <p class="text-sm text-gray-600 mb-3">Security review does not suspend or deactivate either account. Account restrictions require a separate authorized security action.</p>
      <% end %>
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm mb-5">
        <div>
          <dt class="text-gray-500">Last updated by</dt>
          <dd class="text-gray-900"><%= @review_case.reviewed_by&.email || 'Unknown' %></dd>
        </div>
        <div>
          <dt class="text-gray-500">Last updated at</dt>
          <dd class="text-gray-900"><%= @review_case.reviewed_at&.strftime('%B %d, %Y at %I:%M %p') || '—' %></dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-gray-500">Rationale</dt>
          <dd class="text-gray-900 whitespace-pre-line"><%= @review_case.review_rationale.presence || 'Not recorded' %></dd>
        </div>
      </dl>
      <h3 class="text-base font-medium text-gray-900 mb-2">Ready to continue?</h3>
      <%= render 'resume_form', review_case: @review_case, prefill: @resume_prefill %>
    </section>
  <% else %>
    <section class="bg-white shadow sm:rounded-md p-4 mt-8" aria-labelledby="resolution-heading" data-testid="resolution-summary">
      <h2 id="resolution-heading" class="text-lg font-medium text-gray-900 mb-3">Resolution</h2>
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
        <div>
          <dt class="text-gray-500">Outcome</dt>
          <dd class="text-gray-900"><%= duplicate_review_status_label(@review_case.status) %></dd>
        </div>
        <div>
          <dt class="text-gray-500">Resolved by</dt>
          <dd class="text-gray-900"><%= @review_case.resolved_by&.email || 'Unknown' %></dd>
        </div>
        <div>
          <dt class="text-gray-500">Resolved at</dt>
          <dd class="text-gray-900"><%= @review_case.resolved_at&.strftime('%B %d, %Y at %I:%M %p') || '—' %></dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-gray-500">Rationale</dt>
          <dd class="text-gray-900 whitespace-pre-line"><%= @review_case.review_rationale.presence || 'Not recorded' %></dd>
        </div>
      </dl>
    </section>
  <% end %>
</div>
