<% provider_info_request_summaries = local_assigns.fetch(:provider_info_request_summaries, {}) %>

<div class="bg-white shadow overflow-x-auto sm:rounded-lg">
  <table class="min-w-full divide-y divide-gray-200 applications-table" role="table" style="table-layout: fixed;">
    <thead class="bg-gray-50" role="rowgroup">
      <tr role="row"> 
        <th scope="col" class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap" role="columnheader" style="width: 7%;">
          <%= link_to applications_sort_path('application_date'),
                      class: "flex items-center",
                      aria: { label: "Sort applications by Date" },
                      data: { turbo_frame: "applications_list" } do %>
            Date
            <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          <% end %>
        </th>
        <th scope="col" class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider" role="columnheader" style="width: 11%;">
          <%= link_to applications_sort_path('user.last_name'),
                      class: "flex items-center",
                      aria: { label: "Sort applications by Applicant" },
                      data: { turbo_frame: "applications_list" } do %>
            Applicant
            <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          <% end %>
        </th>
        <th scope="col" class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider" role="columnheader" style="width: 12%;">Managing Guardian</th>
        <th scope="col" class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider hidden sm:table-cell" role="columnheader" style="width: 9%;">Phone</th>
        <th scope="col" class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider" role="columnheader" style="width: 15%;">Email</th>
        <th scope="col" class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap" role="columnheader" style="width: 8%;">
          <%= link_to applications_sort_path('status'),
                      class: "flex items-center",
                      aria: { label: "Sort applications by Status" },
                      data: { turbo_frame: "applications_list" } do %>
            Status
            <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          <% end %>
        </th>
        <th scope="col" class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider" role="columnheader" style="width: 15%;">Attachments</th>
        <th scope="col" class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap" role="columnheader" style="width: 11%;">Medical Response</th>
        <th scope="col" class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap" role="columnheader" style="width: 8%;">Action</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200" role="rowgroup">
      <% applications.each do |application| %>
        <tr id="application_<%= application.id %>" class="application-row h-20 focus:outline-none focus:ring-2 focus:ring-indigo-500 <%= 'bg-blue-50' if application.for_dependent? %>" role="row"> <!-- Added application-row class here -->
          <td class="px-2 py-2 text-sm text-gray-900 whitespace-nowrap overflow-hidden" role="cell">
            <%= application.application_date.strftime("%m/%d/%Y") %>
          </td>
          <td class="px-2 py-2 text-sm text-gray-900 overflow-hidden" role="cell">
            <div class="truncate" title="<%= application.user&.full_name || 'Unknown Applicant' %>">
              <% if application.user.present? %>
                <%= link_to application.user.full_name, admin_user_path(application.user), class: "font-semibold text-indigo-600 hover:text-indigo-500", aria: { label: "View user details" }, data: { turbo_frame: "_top" } %>
              <% else %>
                Unknown Applicant
              <% end %>
            </div>
          </td>
          <td class="px-2 py-2 text-sm text-gray-900 overflow-hidden" role="cell">
            <% if application.managing_guardian.present? %>
              <div class="truncate" title="<%= application.managing_guardian.full_name %>">
                <span class="font-semibold"><%= application.managing_guardian.full_name %></span>
                <%# Use preloaded guardian_relationships_as_dependent to avoid N+1 queries %>
                <% if application.user.present? %>
                  <% guardian_relationship = application.user.guardian_relationships_as_dependent.find { |rel| rel.guardian_id == application.managing_guardian_id } %>
                  <% if guardian_relationship %>
                    <span class="text-gray-600 text-xs ml-1">(<%= guardian_relationship.relationship_type %>)</span>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              N/A
            <% end %>
          </td>
          <td class="px-2 py-2 text-sm text-gray-900 hidden sm:table-cell whitespace-nowrap overflow-hidden" role="cell">
            <div class="truncate">
              <% if application.user.present? %>
                <%= application.user.phone || "No phone" %>
              <% else %>
                No phone
              <% end %>
            </div>
          </td>
          <td class="px-2 py-2 text-sm text-gray-900 overflow-hidden" role="cell">
            <div class="truncate" title="<%= application.user&.effective_email || 'No email' %>">
              <% if application.user.present? %>
                <%= application.user.effective_email || "No email" %>
              <% else %>
                No email
              <% end %>
            </div>
          </td>
          <td class="px-2 py-2 text-sm text-gray-900 overflow-hidden" role="cell">
            <%= application_status_badge(application) %>
          </td>
          <td class="px-2 py-2 text-sm text-gray-900 overflow-hidden" role="cell">
            <% 
              # Use our decorator's safe methods to check attachment status
              income_attached = application.respond_to?(:income_proof_attached?) ? 
                application.income_proof_attached? : 
                (application.respond_to?(:income_proof) && application.income_proof.attached?)
                
              residency_attached = application.respond_to?(:residency_proof_attached?) ? 
                application.residency_proof_attached? : 
                (application.respond_to?(:residency_proof) && application.residency_proof.attached?)
            %>
            
            <% if income_attached || residency_attached %>
              <div class="flex flex-col space-y-1">
                <div class="flex items-center space-x-2">
                  <span class="text-sm text-gray-600">Income:</span>
                  <%= proof_status_badge('income', application.income_proof_status) %>
                </div>
                <div class="flex items-center space-x-2">
                  <span class="text-sm text-gray-600">Residency:</span>
                  <%= proof_status_badge('residency', application.residency_proof_status) %>
                </div>
                <div class="flex items-center space-x-2">
                  <span class="text-sm text-gray-600">ID:</span>
                  <%= proof_status_badge('id', application.id_proof_status) %>
                </div>
              </div>
            <% else %>
              <span class="text-sm text-gray-500">No Proofs</span>
            <% end %>
          </td>
          <td class="px-2 py-2 text-sm text-gray-900 overflow-hidden" role="cell">
            <%= medical_certification_status_badge(application) %>
            <% if (provider_info_summary = provider_info_request_summaries&.[](application.id)) %>
              <div class="mt-2 rounded-md border border-amber-200 bg-amber-50 px-2 py-1 text-xs text-amber-900"
                   aria-label="<%= secure_request_summary_accessible_label(provider_info_summary) %>">
                <div class="font-medium"><%= t('admin.applications.secure_request_forms.summary.label') %></div>
                <% if provider_info_summary[:recipient_count].zero? %>
                  <div class="text-amber-800"><%= t('admin.applications.secure_request_forms.summary.none') %></div>
                <% else %>
                  <div class="text-amber-800"><%= secure_request_summary_recipient_count(provider_info_summary) %></div>
                  <div class="text-amber-800"><%= secure_request_summary_status_counts(provider_info_summary) %></div>
                  <% if (sent_text = secure_request_summary_sent_text(provider_info_summary)) %>
                    <div class="text-amber-800"><%= sent_text %></div>
                  <% end %>
                  <% if (expiration_text = secure_request_summary_expiration_text(provider_info_summary)) %>
                    <div class="text-amber-800"><%= expiration_text %></div>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </td>
          <td class="px-2 py-2 text-sm font-medium overflow-hidden">
            <%= link_to "View Application",
                admin_application_path(id: application.id),
                class: "text-indigo-600 hover:text-indigo-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 whitespace-nowrap",
                aria: { label: "View details for #{application.user&.full_name || 'Unknown User'}" },
                data: { turbo_frame: "_top" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
