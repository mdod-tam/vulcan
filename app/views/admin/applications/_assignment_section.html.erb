<%# Shared partial for Evaluator and Trainer assignment sections
    Parameters:
    - type: 'evaluator' or 'trainer'
    - entity: the evaluation or training_session object
    - assigned_person: the evaluator or trainer person
    - assign_form_path: URL for the assignment POST (single endpoint; the practitioner id is sent as a form field)
    - assign_param: :trainer_id or :evaluator_id (the param name the controller expects)
    - view_path: path for viewing details
    - unassign_form_path: optional path for removing the current assignment
    - available_assignees: collection of available people to assign
    - status_badge_method: method to render badge (evaluation_status_badge or training_session_status_badge)
    - assignment_heading: optional heading for unassigned assignment form
    - assignment_submit_label: optional submit label for unassigned assignment form
    - assignment_select_label: optional accessible label for unassigned assignment select
%>

<div class="rounded-lg border border-gray-200 bg-gray-50 p-4" data-testid="<%= type %>-assignment-section">
  <% if entity.present? %>
    <!-- Display assigned person information -->
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div>
        <h3 class="text-sm font-semibold text-gray-900">Current <%= type.titleize %></h3>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <% if assigned_person.present? %>
            <span class="text-sm text-gray-900"><%= assigned_person.full_name %></span>
          <% else %>
            <span class="text-sm text-gray-500">No <%= type.titleize %> Assigned</span>
          <% end %>
          <%= send(status_badge_method, entity) %>
        </div>
        <% if local_assigns[:scheduled_date].present? %>
          <p class="text-sm text-gray-500 mt-1">
            Scheduled for: <%= scheduled_date.strftime("%B %d, %Y" + (scheduled_time ? " at %I:%M %p" : "")) %>
          </p>
        <% end %>
      </div>
      <% if view_path.present? && (!entity.respond_to?(:status_completed?) || !entity.status_completed?) %>
        <div class="flex flex-col gap-2 sm:flex-row">
          <%= link_to("View Details",
              view_path,
              class: "inline-flex h-10 items-center justify-center rounded-md border border-indigo-300 bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 shadow-sm hover:bg-indigo-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2",
              data: { turbo_frame: "_top" }) %>
          <% if local_assigns[:unassign_form_path].present? %>
            <%= button_to("Unassign #{type.titleize}",
                unassign_form_path,
                method: :post,
                class: "inline-flex h-10 items-center justify-center rounded-md border border-red-300 bg-white px-4 py-2 text-sm font-medium text-red-700 shadow-sm hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2",
                data: { turbo_confirm: "Remove this #{type} assignment?" },
                aria: { label: "Unassign #{assigned_person&.full_name || type.titleize}" }) %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Dropdown assignment: one select, one submit -->
    <h3 class="text-sm font-semibold text-gray-900 mb-3"><%= local_assigns[:assignment_heading].presence || "Assign #{type.titleize}" %></h3>
    <% if available_assignees.blank? %>
      <p class="text-sm text-gray-500">No <%= type.pluralize %> are currently available for assignment.</p>
    <% else %>
      <%= form_with url: assign_form_path, method: :post, local: true, data: { testid: "#{type}-assignment-form" }, class: "flex max-w-2xl flex-col gap-3 sm:flex-row sm:items-end" do |f| %>
        <div class="w-full sm:max-w-md">
          <%= label_tag assign_param, local_assigns[:assignment_select_label].presence || "Select #{type.titleize.downcase}", class: "sr-only" %>
          <%= select_tag assign_param,
              options_from_collection_for_select(available_assignees, :id, :full_name),
              include_blank: "Select a #{type}…",
              class: "block h-10 w-full rounded-md border-gray-300 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500",
              required: true %>
        </div>
        <%= submit_tag local_assigns[:assignment_submit_label].presence || "Assign #{type.titleize}",
            class: "inline-flex h-10 items-center justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
      <% end %>
    <% end %>
  <% end %>
</div>
