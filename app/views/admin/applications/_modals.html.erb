<%# Locals for common values and rejection strings %>
<% time_query    = "&t=#{Time.current.to_i}" %>
<% proof_files   = { income: @application.income_proof,
                     residency: @application.residency_proof,
                     id: @application.id_proof,
                     medical: @application.medical_certification } %>
<% proof_urls    = proof_files.transform_values { |f| f.attached? ? rails_blob_path(f, disposition: :inline) : nil } %>

<%# Address components for rejection message interpolation %>
<% address_1 = @application.user&.physical_address_1.to_s %>
<% address_2 = @application.user&.physical_address_2.presence || '' %>
<% city      = @application.user&.city.to_s %>
<% state     = @application.user&.state.to_s %>
<% zip       = @application.user&.zip_code.to_s %>
<% full_address = "#{address_1} #{address_2} #{city}, #{state} #{zip}".squish %>
<% preferred_locale = @application.user&.effective_locale.to_s.presence || @application.user&.locale.to_s.presence || 'en' %>

<%# Helper to interpolate address placeholders in rejection reason bodies %>
<% interpolate_address = lambda do |body|
     body.gsub('%<address>s', full_address) if body
   end %>
<% proof_custom_language_notice = if preferred_locale == 'es'
                                    'Applicant prefers to receive Spanish communications. Please ensure any custom rejection reason is translated.'
                                  else
                                    'Applicant prefers to receive English communications.'
                                  end %>
<% medical_custom_language_notice = 'Disability certification communications are sent to the certificate signer in English.' %>

<% reason_button_classes = "px-3 py-1 rounded border border-gray-300 bg-gray-100 text-gray-800 hover:bg-gray-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-1" %>

<%# Helper to render PDF/Image attachment preview %>
<%
def render_attachment(attachment, url, time_query)
  return content_tag(:p, "No file attached.", class: "text-gray-500") unless attachment&.attached? && url.present?

  if attachment.content_type.start_with?('application/pdf')
    # Capture the PDF block as a string
    pdf_block = capture do
%>
      <%#
        IMPORTANT: PDF Preview Fix

        Setting both src and data-original-src attributes is critical for PDF previews to work correctly.
        Previous implementations only set data-original-src and relied on JavaScript to set the src,
        but this was unreliable and often resulted in blank PDF previews.

        The current implementation:
        1. Sets the src attribute directly in the HTML
        2. Also keeps data-original-src for the modal controller to use
        3. Uses data-turbo="false" to prevent Turbo from interfering with the iframe

        DO NOT REMOVE the src attribute or change this implementation without thorough testing.
        Changes here have repeatedly broken PDF previews in the past.
      %>
      <div class="pdf-container">
        <iframe
          src="<%= url + time_query %>"
          data-original-src="<%= url + time_query %>"
          data-turbo="false"
          width="100%"
          height="500px"
          class="border-0"
          frameborder="0"></iframe>
        <div class="pdf-fallback bg-gray-50 border rounded p-4 mt-2">
          <p class="text-gray-700 mb-2">If the PDF doesn't display properly:</p>
          <%= link_to "Open PDF in new window",
              url,
              target: "_blank",
              class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700" %>
        </div>
      </div>
<%
    end # capture
    pdf_block # Return the captured block
  else
    # Return the image tag
    image_tag url_for(attachment), class: "max-w-full h-auto"
  end
end
%>

<div id="modals">
  <!-- Certification History Modal -->
  <%= render "certification_history_modal" %>

  <%# Loop through proof types to generate modals %>
  <% proof_modal_configs = []
     if @application.income_proof_required?
       proof_modal_configs << { id: 'incomeProofReviewModal',  key: :income,   title: 'Review Income Proof',   approve_path: update_proof_status_admin_application_path(@application), approve_params: { proof_type: 'income', status: 'approved' }, reject_modal_id: 'proofRejectionModal', reject_proof_type: 'income', confirm_message: "Approve income proof?", can_reject: @application.proof_type_reviewable?("income") }
     end
     proof_modal_configs << { id: 'residencyProofReviewModal', key: :residency, title: 'Review Residency Proof', approve_path: update_proof_status_admin_application_path(@application), approve_params: { proof_type: 'residency', status: 'approved' }, reject_modal_id: 'proofRejectionModal', reject_proof_type: 'residency', confirm_message: "Approve residency proof?", can_reject: @application.proof_type_reviewable?("residency") }
     proof_modal_configs << { id: 'idProofReviewModal', key: :id, title: 'Review ID Proof', approve_path: update_proof_status_admin_application_path(@application), approve_params: { proof_type: 'id', status: 'approved' }, reject_modal_id: 'proofRejectionModal', reject_proof_type: 'id', confirm_message: "Approve ID proof?", can_reject: @application.proof_type_reviewable?("id") }
     proof_modal_configs << { id: 'medicalCertificationReviewModal', key: :medical, title: 'Review Disability Certification', approve_path: update_certification_status_admin_application_path(@application), approve_params: { status: 'accepted' }, reject_modal_id: 'medicalCertificationRejectionModal', reject_proof_type: 'medical', confirm_message: "Approve this disability certification?", can_reject: !@application.medical_certification_status_rejected? || @application.medical_certification_status_received? }
  %>
  <% proof_modal_configs.each do |cfg| %>
    <dialog id="<%= cfg[:id] %>" class="backdrop:bg-gray-500 backdrop:bg-opacity-75 bg-white rounded-lg max-w-3xl w-full shadow-xl p-0" data-controller="modal" aria-labelledby="<%= cfg[:id] %>-heading">
      <div class="p-6">
          <h3 id="<%= cfg[:id] %>-heading" class="text-lg font-medium text-gray-900 mb-4"><%= cfg[:title] %></h3>

          <%# Guardian Alert (only for income/residency) %>
          <% if cfg[:key] != :medical && @application.for_dependent? %>
            <div class="mb-4 rounded-md bg-amber-50 p-4 border border-amber-300">
              <div class="flex">
                <div class="flex-shrink-0">
                  <!-- Alert icon -->
                  <svg class="h-5 w-5 text-amber-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M8.485 3.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 3.495zM10 6a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 6zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="ml-3">
                  <h3 class="text-sm font-medium text-amber-800">Guardian Application</h3>
                  <div class="mt-1 text-sm text-amber-700">
                    <p>This application was submitted by a <strong><%= @application.managing_guardian.full_name %></strong> (<%= @application.guardian_relationship_type&.downcase || "guardian" %>) on behalf of a dependent. Please verify this relationship when reviewing these proof documents.</p>
                    
                    <% if cfg[:key] == :residency %>
                      <%# Show address information for residency proof review %>
                      <% if @application.user.present? %>
                        <% 
                          address_parts = []
                          address_parts << @application.user.physical_address_1 if @application.user.physical_address_1.present?
                          address_parts << @application.user.physical_address_2 if @application.user.physical_address_2.present?
                          full_address = address_parts.join(", ")
                          full_address += ", #{@application.user.city}, #{@application.user.state} #{@application.user.zip_code}" if @application.user.city.present?
                        %>
                        
                        <% if full_address.present? %>
                          <p class="mt-2"><strong>The address entered for the application was:</strong> <%= full_address %></p>
                        <% else %>
                          <%# Check if guardian has address information %>
                          <% if @application.managing_guardian.present? %>
                            <% 
                              guardian_address_parts = []
                              guardian_address_parts << @application.managing_guardian.physical_address_1 if @application.managing_guardian.physical_address_1.present?
                              guardian_address_parts << @application.managing_guardian.physical_address_2 if @application.managing_guardian.physical_address_2.present?
                              guardian_full_address = guardian_address_parts.join(", ")
                              guardian_full_address += ", #{@application.managing_guardian.city}, #{@application.managing_guardian.state} #{@application.managing_guardian.zip_code}" if @application.managing_guardian.city.present?
                            %>
                            <% if guardian_full_address.present? %>
                              <p class="mt-2"><strong>The guardian's address on file is:</strong> <%= guardian_full_address %></p>
                            <% end %>
                          <% end %>
                        <% end %>
                      <% end %>
                    <% elsif cfg[:key] == :income %>
                      <%# Show income and household size information for income proof review %>
                      <% if @application.annual_income.present? || @application.household_size.present? %>
                        <p class="mt-2">
                          <strong>
                            <% if @application.annual_income.present? && @application.household_size.present? %>
                              The income entered during the application was <%= number_to_currency(@application.annual_income) %> and the family size was <%= @application.household_size %>.
                            <% elsif @application.annual_income.present? %>
                              The income entered during the application was <%= number_to_currency(@application.annual_income) %>.
                            <% elsif @application.household_size.present? %>
                              The family size entered during the application was <%= @application.household_size %>.
                            <% end %>
                          </strong>
                        </p>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <%# Render attachment preview %>
          <%= render_attachment(proof_files[cfg[:key]], proof_urls[cfg[:key]], time_query) %>

          <%# Action Buttons %>
          <div class="mt-4 flex space-x-4">
            <%= button_to cfg[:approve_path],
                method: :patch,
                params: cfg[:approve_params],
                class: "inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-md",
                data: {
                  turbo: true,
                  confirm: cfg[:confirm_message]
                } do %>
              Approve
            <% end %>
            <% latest_rejected_review = if cfg[:key] == :medical
                                          @application.latest_medical_rejection_review
                                        else
                                          @application.proof_reviews.where(proof_type: cfg[:key], status: 'rejected').order(created_at: :desc).first
                                        end %>
            <% if cfg[:can_reject] %>
              <button type="button"
                      data-action="click->modal#open"
                      data-modal-id="<%= cfg[:reject_modal_id] %>"
                      data-proof-type="<%= cfg[:reject_proof_type] %>"
                      class="inline-flex items-center px-4 py-2 bg-red-600 text-white rounded-md">
                Reject
              </button>
            <% elsif latest_rejected_review.present? %>
              <span class="inline-flex items-center px-4 py-2 text-sm text-gray-500 italic">
                Previously rejected on <%= latest_rejected_review.created_at.strftime('%B %d, %Y') %>
              </span>
            <% end %>
          </div>
          <div class="mt-4">
            <button type="button"
                    data-action="click->modal#close"
                    class="px-4 py-2 border border-gray-300 rounded-md text-gray-700"
                    aria-label="Close proof review modal">
              Close
            </button>
          </div>
      </div>
    </dialog>
  <% end %>

  <!-- Rejection Modal for Proof Reviews -->
  <dialog id="proofRejectionModal" class="backdrop:bg-gray-500 backdrop:bg-opacity-75 bg-white rounded-lg max-w-lg w-full shadow-xl p-0" data-controller="modal rejection-form"
       aria-labelledby="proofRejectionModal-heading">
    <div class="p-6">
        <h3 id="proofRejectionModal-heading" class="text-lg font-medium text-gray-900 mb-4">Enter Rejection Reason</h3>
        <p class="sr-only" data-rejection-form-target="liveRegion" aria-live="polite" aria-atomic="true"></p>
        <div class="mb-4">
          <p class="text-sm font-medium text-gray-700 mb-1">Predefined Rejection Reasons:</p>
          <%# Group rejection reasons by code and proof_type %>
          <% rejection_reasons_by_code = RejectionReason.where(locale: [preferred_locale, 'en'])
                                                        .where.not(code: %w[none_provided other])
                                                        .group_by { |r| [r.code, r.proof_type] }
                                                        .transform_values do |reasons|
                                                          preferred_reason = reasons.find { |r| r.locale == preferred_locale } || reasons.first
                                                          {
                                                            reason: preferred_reason,
                                                            proof_type: preferred_reason.proof_type
                                                          }
                                                        end %>
          <div class="flex flex-wrap gap-2 mb-2 general-reasons" data-rejection-form-target="generalReasons">
            <% rejection_reasons_by_code.each do |(code, proof_type), data| %>
              <% reason = data[:reason] %>
              <% display_proof_type = proof_type == 'medical_certification' ? 'medical' : proof_type %>
              <% interpolated_body = interpolate_address.call(reason.body) %>
              <% label = code.humanize %>
              <button type="button"
                      class="<%= reason_button_classes %>"
                      data-action="click->rejection-form#selectPredefinedReason"
                      data-reason-code="<%= code %>"
                      data-reason-text="<%= interpolated_body %>"
                      data-proof-types="<%= display_proof_type %>"
                      data-rejection-form-target="reasonButton"
                      aria-label="Select <%= label %> rejection reason"
                      aria-pressed="false">
                <%= label %>
              </button>
            <% end %>
            <button type="button"
                    class="<%= reason_button_classes %>"
                    data-action="click->rejection-form#selectOther"
                    data-rejection-form-target="reasonButton"
                    data-proof-types="income,residency,id,medical"
                    aria-label="Enter a custom rejection reason"
                    aria-pressed="false">
              Other
            </button>
          </div>
        </div>
        <%= form_with url: update_proof_status_admin_application_path(@application),
                      method: :patch,
                      local: false,
                      class: "space-y-4",
                        data: {
                          turbo: true,
                          action: "submit->rejection-form#validateForm"
                        } do |f| %>
          <%= f.hidden_field :status, value: "rejected" %>
          <%= f.hidden_field :proof_type,
              id: "rejection-proof-type",
              data: { rejection_form_target: "proofType" } %>
          <%= f.hidden_field :rejection_reason_code,
              id: "rejection-reason-code",
              data: { rejection_form_target: "reasonCode" } %>
          <div>
            <%= f.label :rejection_reason, "Reason for Rejection", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_area :rejection_reason,
                rows: 4,
                id: "rejection_reason",
                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm",
                required: true,
                placeholder: "Please provide a detailed explanation...",
                data: { rejection_form_target: "reasonField" } %>
            <div class="hidden mt-2 rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900"
                 data-rejection-form-target="languageNotice">
              <%= proof_custom_language_notice %>
            </div>
            <p class="mt-1 text-xs text-gray-500" data-rejection-form-target="codeStatus">
              No predefined rejection reason selected.
            </p>
          </div>

          <div class="flex justify-end space-x-3">
            <button type="button"
                    data-action="click->modal#close"
                    class="px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50"
                    aria-label="Cancel proof rejection and close modal">
              Cancel
            </button>
            <%= f.submit "Submit",
                class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700" %>
          </div>
        <% end %>
    </div>
  </dialog>

  <!-- Disability Certification Rejection Modal -->
  <dialog id="medicalCertificationRejectionModal" class="backdrop:bg-gray-500 backdrop:bg-opacity-75 bg-white rounded-lg max-w-lg w-full shadow-xl p-0" data-controller="modal rejection-form"
       aria-labelledby="medicalCertificationRejectionModal-heading">
    <div class="p-6">
        <h3 id="medicalCertificationRejectionModal-heading" class="text-lg font-medium text-gray-900 mb-4">Enter Disability Certification Rejection Reason</h3>
        <p class="sr-only" data-rejection-form-target="liveRegion" aria-live="polite" aria-atomic="true"></p>
        <div class="mb-4">
          <p class="text-sm font-medium text-gray-700 mb-1">Predefined Rejection Reasons:</p>
          <%# Medical certification reasons only %>
          <% medical_reasons = RejectionReason.where(proof_type: 'medical_certification', locale: [preferred_locale, 'en'])
                                               .where.not(code: %w[none_provided other])
                                               .group_by(&:code)
                                               .transform_values do |reasons|
                                                 preferred_reason = reasons.find { |r| r.locale == preferred_locale } || reasons.first
                                                 preferred_reason
                                               end %>
          <div class="flex flex-wrap gap-2 mb-2 medical-only-reasons" data-rejection-form-target="medicalOnlyReasons">
            <% medical_reasons.each do |code, reason| %>
              <% interpolated_body = interpolate_address.call(reason.body) %>
              <% label = code.humanize %>
              <button type="button"
                      class="<%= reason_button_classes %>"
                      data-action="click->rejection-form#selectPredefinedReason"
                      data-reason-code="<%= code %>"
                      data-reason-text="<%= interpolated_body %>"
                      data-rejection-form-target="reasonButton"
                      aria-label="Select <%= label %> rejection reason"
                      aria-pressed="false">
                <%= label %>
              </button>
            <% end %>
            <button type="button"
                    class="<%= reason_button_classes %>"
                    data-action="click->rejection-form#selectOther"
                    data-rejection-form-target="reasonButton"
                    aria-label="Enter a custom rejection reason"
                    aria-pressed="false">
              Other
            </button>
          </div>
        </div>
        <%= form_with url: update_certification_status_admin_application_path(@application),
                      method: :patch,
                      local: false,
                      class: "space-y-4",
                        data: {
                          turbo: true,
                          action: "submit->rejection-form#validateForm"
                        } do |f| %>
          <%= f.hidden_field :status, value: "rejected" %>
          <%= f.hidden_field :proof_type,
              id: "medical-rejection-proof-type",
              value: "medical",
              data: { rejection_form_target: "proofType" } %>
          <%= f.hidden_field :rejection_reason_code,
              id: "medical-rejection-reason-code",
              data: { rejection_form_target: "reasonCode" } %>
          <div>
            <%= f.label :rejection_reason, "Reason for Rejection", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_area :rejection_reason,
                rows: 4,
                id: "rejection_reason",
                class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm",
                required: true,
                placeholder: "Please provide a detailed explanation...",
                data: { rejection_form_target: "reasonField" } %>
            <div class="hidden mt-2 rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900"
                 data-rejection-form-target="languageNotice">
              <%= medical_custom_language_notice %>
            </div>
            <p class="mt-1 text-xs text-gray-500" data-rejection-form-target="codeStatus">
              No predefined rejection reason selected.
            </p>
          </div>

          <div class="flex justify-end space-x-3">
            <button type="button"
                    data-action="click->modal#close"
                    class="px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50"
                    aria-label="Cancel disability certification rejection and close modal">
              Cancel
            </button>
            <%= f.submit "Submit",
                class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700" %>
          </div>
        <% end %>
    </div>
  </dialog>
</div>
