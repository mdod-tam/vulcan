<%# Medical Certification Section Content
     This partial is rendered inside #medical-certification-section and can be
     updated via Turbo Stream for a smooth UX without full page reload.
%>
<div class="flex justify-between items-start">
  <div class="flex items-center gap-3">
    <h2 id="certification-title" class="text-xl font-semibold text-gray-900">Disability Certification</h2>
    <% if @application.medical_certification_status == 'not_requested' %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-sm font-medium bg-gray-100 text-gray-700">
        Not Requested
      </span>
    <% end %>
  </div>
  <div class="flex items-center space-x-2">
    <%= medical_certification_status_badge(@application) %>
    <%= document_signing_status_badge(@application) %>
  </div>
</div>

<div class="mt-6 space-y-4">
  <!-- Disability Certification Upload Form (Visible unless approved) -->
  <%= render "medical_certification_upload" %>

  <!-- Medical Certification -->
  <% if @application.medical_certification.attached? %>
    <div class="mb-4" data-testid="medical-certification">
      <h3 class="text-sm font-medium text-gray-700 mb-2">Medical Certification</h3>
      <div class="pl-4 border-l-2 border-gray-200">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-900">
              <%= @application.medical_certification.blob.filename %>
            </p>
            <p class="text-xs text-gray-500">
              <%= number_to_human_size(@application.medical_certification.blob.byte_size) %>
            </p>
          </div>
          <a href="<%= rails_blob_path(@application.medical_certification, disposition: "attachment") %>"
             class="inline-flex items-center px-3 py-1 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700"
             download>
            Download
          </a>
        </div>
      </div>
    </div>
  <% end %>

  <% if @application.additional_medical_certifications.attached? %>
    <div class="mb-4" data-testid="additional-medical-certifications">
      <h3 class="text-sm font-medium text-gray-700 mb-2">Additional Certification Submissions</h3>
      <div class="space-y-2 pl-4 border-l-2 border-gray-200">
        <% @application.additional_medical_certifications.each do |certification| %>
          <div class="flex items-center justify-between">
            <div class="min-w-0">
              <p class="text-sm font-medium text-gray-900 break-all">
                <%= certification.blob.filename %>
              </p>
              <p class="text-xs text-gray-500">
                <%= additional_medical_certification_source_label(certification) %> · <%= number_to_human_size(certification.blob.byte_size) %>
              </p>
            </div>
            <a href="<%= rails_blob_path(certification, disposition: "attachment") %>"
               class="shrink-0 ml-3 inline-flex items-center px-3 py-1 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700"
               download>
              Download
            </a>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Provider Information -->
  <% if @application.medical_provider_info_present? %>
    <div class="mb-4" data-testid="provider-information">
      <h3 class="text-sm font-medium text-gray-700 mb-2">Provider Information</h3>
      <div class="pl-4 border-l-2 border-gray-200">
        <% if @application.medical_provider_name.present? %>
          <p class="text-sm font-medium text-gray-900"><%= @application.medical_provider_name %></p>
        <% end %>
        <% if @application.medical_provider_phone.present? || (@application.respond_to?(:medical_provider_fax) && @application.medical_provider_fax.present?) %>
          <p class="text-sm text-gray-600">
            <% if @application.medical_provider_phone.present? %>
              Phone: <%= @application.medical_provider_phone %>
            <% end %>
            <% if @application.respond_to?(:medical_provider_fax) && @application.medical_provider_fax.present? %>
              <% if @application.medical_provider_phone.present? %> / <% end %>
              Fax: <%= @application.medical_provider_fax %>
            <% end %>
          </p>
        <% end %>
        <% if @application.medical_provider_email.present? %>
          <p class="text-sm text-gray-600">Email: <%= @application.medical_provider_email %></p>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= render "medical_provider_secure_request_forms_panel" %>

  <!-- Action Buttons -->
  <div class="mt-6">
    <%
      certification_action_state = medical_certification_action_state(
        @application,
        secure_request_forms: @medical_provider_secure_request_forms
      )
    %>

    <% if show_medical_certification_request_buttons?(@application) && !@application.document_signing_status_signed? %>
      <div class="flex flex-wrap gap-2">
        <!-- DocuSeal Button (Default) -->
      <% if FeatureFlag.enabled?(:docusign_enabled, default: true) %>
        <% if certification_action_state.provider_ready_for_docuseal %>
          <%= button_to send_document_signing_request_admin_application_path(@application),
              method: :post,
              class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500",
              form: {
                data: {
                  turbo_confirm: certification_action_state.docuseal_confirm
                }
              },
              data: {
                disable_with: "Sending..."
              },
              'aria-label': "Send DocuSeal digital signing request to #{@application.medical_provider_name}" do %>
            <%= certification_action_state.docuseal_text %>
          <% end %>
        <% else %>
          <button disabled 
                  aria-disabled="true"
                  title="Provider name and email required for DocuSeal"
                  class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-400 bg-gray-100 cursor-not-allowed">
            <%= certification_action_state.docuseal_text %>
          </button>
        <% end %>
      <% end %>
        <!-- Print Button (Alternative) -->
        <%= button_to queue_medical_certification_form_admin_application_path(@application),
            method: :post,
            class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500",
            data: {
              disable_with: "Queuing...",
              turbo_confirm: "Add Disability Certification Form to the print queue?"
            },
            'aria-label': "Queue disability certification form for printing" do %>
          Print DCF
        <% end %>
      </div>

    <% elsif (@application.medical_certification_status == "received" ||
           (@application.medical_certification_status == "requested" && @application.medical_certification.attached?) ||
           certification_action_state.requested_after_rejection) &&
           !["approved"].include?(@application.medical_certification_status) %>
      <!-- Review button - Show this only when we have a certification to review AND it's not already accepted/approved -->
      <button type="button"
            data-action="click->modal#open"
            data-modal-id="medicalCertificationReviewModal"
            class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
        Review Disability Certification
      </button>
    <% end %>

    <% if show_secure_cert_upload_button?(@application) %>
      <div class="mt-2 flex flex-wrap gap-2">
        <% if @application.medical_provider_email.present? %>
          <%= button_to admin_application_certification_upload_request_path(@application),
              method: :post,
              class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500",
              form: {
                onsubmit: "return confirm(#{certification_action_state.secure_cert_upload_confirm.to_json})",
                data: {
                  turbo: false
                }
              },
              data: {
                disable_with: "Sending..."
              },
              'aria-label': "Send secure certification upload link to #{@application.medical_provider_name}" do %>
            Send Secure Cert Upload Link
          <% end %>
        <% else %>
          <button disabled
                  aria-disabled="true"
                  title="<%= certification_action_state.secure_cert_upload_message %>"
                  class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-400 bg-gray-100 cursor-not-allowed">
            Send Secure Cert Upload Link
          </button>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
