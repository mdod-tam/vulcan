<%# B snapshot charts — FY cohort by current status %>
<%= turbo_frame_tag "charts_section" do %>
<section aria-labelledby="charts-heading" class="mb-6">
  <h2 id="charts-heading" class="sr-only">Application Charts</h2>
  <p class="text-sm text-gray-600 mb-4">
    Snapshot: applications <strong>created</strong> in <%= @metrics[:current_fy_range_label] %>, grouped by <strong>current</strong> status.
    This is not MFR (see System Reports).
  </p>
  <div class="bg-white rounded-lg shadow p-6">
    <h3 id="status-breakdown-heading" class="text-lg font-medium text-gray-900 mb-2">
      <%= @metrics[:current_fy_label] %> Application Status Snapshot
    </h3>
    <p class="text-sm text-gray-500 mb-4"><%= @metrics[:current_fy_range_label] %></p>

    <div class="overflow-x-auto mb-4">
      <table class="min-w-full text-sm" aria-labelledby="status-breakdown-heading">
        <caption class="sr-only">Application counts by current status for the fiscal year cohort</caption>
        <thead>
          <tr class="border-b border-gray-200">
            <th scope="col" class="text-left py-2 pr-4 font-medium text-gray-700">Status</th>
            <th scope="col" class="text-right py-2 font-medium text-gray-700">Count</th>
          </tr>
        </thead>
        <tbody>
          <% @metrics[:status_counts].each do |status_key, count| %>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4 text-gray-600"><%= status_key.to_s.humanize %></td>
              <td class="py-2 text-right font-medium text-gray-900"><%= count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <p id="status-chart-desc" class="sr-only">
      Chart showing the same status counts as the table above for <%= @metrics[:current_fy_range_label] %>.
    </p>
    <div data-controller="reports-chart"
         data-reports-chart-current-data-value="<%= @metrics[:status_chart_data].to_json %>"
         data-reports-chart-previous-data-value="{}"
         data-reports-chart-current-dataset-label-value="<%= @metrics[:current_fy_label] %>"
         data-reports-chart-type-value="bar"
         data-reports-chart-title-value="<%= @metrics[:current_fy_label] %> Application Status Snapshot"
         class="relative w-full h-80"
         aria-describedby="status-chart-desc">
    </div>
  </div>
</section>
<% end %>
