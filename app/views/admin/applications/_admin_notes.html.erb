<section class="bg-white rounded-lg shadow p-6 mb-6" aria-labelledby="notes-title">
  <h2 id="notes-title" class="text-xl font-semibold text-gray-900 mb-4">Admin Notes</h2>

  <!-- Note Form -->
  <div class="mb-6 pb-6 border-b border-gray-200">
    <%= form_with model: [:admin, @application, ApplicationNote.new], url: admin_application_notes_path(@application), local: true, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :content, "Add a Note", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_area :content, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Enter your note here..." %>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="flex items-center">
          <%= f.check_box :internal_only, checked: true, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" %>
          <%= f.label :internal_only, "Internal only (not visible to constituent)", class: "ml-2 block text-sm text-gray-900" %>
        </div>
        <div>
          <%= f.label :assigned_to_id, "Assign to", class: "block text-sm font-medium text-gray-700" %>
          <%= f.select :assigned_to_id, options_for_select([["No assignment", nil]] + User.where(type: "Users::Administrator").active.map { |u| [u.full_name, u.id] }), {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
        </div>
      </div>
      <div class="mt-2">
        <%= f.submit "Add Note", class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      </div>
    <% end %>
  </div>

  <!-- Notes List -->
  <div>
    <% if @application.application_notes.any? %>
      <ul class="space-y-4">
        <% @application.application_notes.recent_first.each do |note| %>
          <li class="bg-gray-50 p-4 rounded-md">
            <div class="flex justify-between items-start gap-4" id="application-note-<%= note.id %>">
              <div class="flex-1">
                <p class="text-sm text-gray-900"><%= note.content %></p>
                <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-gray-500">
                  <span><%= note.admin.full_name %></span>
                  <span class="mx-1">•</span>
                  <span><%= note.created_at.strftime("%B %d, %Y at %I:%M %p") %></span>
                  <% if note.internal_only %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                      Internal Only
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">
                      Visible to Constituent
                    </span>
                  <% end %>
                  <% if note.assigned_to.present? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                      Assigned to <%= note.assigned_to.full_name %>
                    </span>
                  <% end %>
                  <% if note.completed_at.present? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">
                      ✓ Done
                    </span>
                  <% end %>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <% if note.assigned_to.present? && note.assigned_to == current_user %>
                  <% if note.completed_at.present? %>
                    <%= button_to "Reopen", admin_application_note_path(@application, note), method: :patch, params: { mark_incomplete: true }, class: "text-xs px-2 py-1 text-gray-600 hover:text-gray-900 bg-white border border-gray-300 rounded hover:bg-gray-50", form: { style: "display: inline;" } %>
                  <% else %>
                    <%= button_to "Mark as Done", admin_application_note_path(@application, note), method: :patch, params: { mark_done: true }, class: "text-xs px-2 py-1 text-green-600 hover:text-green-900 bg-white border border-green-300 rounded hover:bg-green-50", form: { style: "display: inline;" } %>
                  <% end %>
                  <%= button_to "Unassign", admin_application_note_path(@application, note), method: :patch, params: { unassign: true }, class: "text-xs px-2 py-1 text-gray-600 hover:text-gray-900 bg-white border border-gray-300 rounded hover:bg-gray-50", form: { style: "display: inline;" } %>
                <% elsif note.assigned_to.present? %>
                  <!-- Note is assigned to someone else, show no action buttons -->
                <% else %>
                  <details class="group">
                    <summary class="text-xs px-2 py-1 text-gray-600 hover:text-gray-900 bg-white border border-gray-300 rounded hover:bg-gray-50 cursor-pointer">
                      Assign
                    </summary>
                    <div class="absolute right-0 mt-1 w-48 bg-white border border-gray-300 rounded-md shadow-lg z-10">
                      <% User.where(type: "Users::Administrator").active.each do |admin| %>
                        <%= button_to admin.full_name, admin_application_note_path(@application, note), method: :patch, params: { assigned_to_id: admin.id }, class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-900 border-b border-gray-100 last:border-b-0", form: { style: "display: block;" } %>
                      <% end %>
                    </div>
                  </details>
                <% end %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-500">No notes have been added yet.</p>
    <% end %>
  </div>
</section>
