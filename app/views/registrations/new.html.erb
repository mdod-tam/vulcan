<!-- Skip Link (visually hidden until focused) -->
<a href="#signup-form"
   class="sr-only focus:not-sr-only absolute top-2 left-2 p-2 bg-white border border-gray-300 text-gray-700 rounded focus:z-50"
   role="link"
   aria-label="Skip to sign up form">
  Skip to main content
</a>

<div class="flex items-center justify-center bg-gray-100 px-4 py-12">
  <div class="bg-white p-6 sm:p-8 rounded-lg shadow-md w-full max-w-md">
    <!-- Page Heading -->
    <header>
      <h1 id="signup-heading" class="text-2xl font-semibold mb-6 text-center text-gray-900">
        Create Account
      </h1>
    </header>

    <p style="text-align: center;" class="text-l text-gray-900"><span style="color: red;">*</span> Indicates a required field</p>

    <!-- Flash/Alert Messages -->
    <% if flash[:alert] %>
      <div role="alert" aria-live="polite" aria-atomic="true"
           class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
        <p><%= flash[:alert] %></p>
      </div>
    <% end %>

    <% if @account_access_conflict %>
      <div role="alert" aria-live="assertive"
           class="bg-yellow-50 border border-yellow-400 text-yellow-900 px-4 py-3 rounded mb-6">
        <h2 class="font-semibold mb-2"><%= t("portal_self_service.registrations.duplicate_conflict_heading") %></h2>
        <p class="text-sm">
          <%= t("portal_self_service.registrations.duplicate_conflict_body", support_email: mail_to(@support_email)).html_safe %>
        </p>
      </div>
    <% elsif @account_access_user.present? %>
      <section class="bg-blue-50 border border-blue-300 text-blue-900 px-4 py-4 rounded mb-6">
        <h2 id="account-access-heading" class="font-semibold mb-2">
          <%= t(
                "portal_self_service.registrations.duplicate_exists_heading",
                match_type: t("portal_self_service.registrations.match_type.#{@account_access_match_type}")
              ) %>
        </h2>
        <% if @account_access_available %>
          <p class="text-sm mb-4">
            <%= t("portal_self_service.registrations.duplicate_available_body") %>
          </p>
        <% else %>
          <p class="text-sm mb-4">
            <%= t("portal_self_service.registrations.duplicate_no_link_body", support_email: mail_to(@support_email)).html_safe %>
          </p>
        <% end %>
        <div class="space-y-3">
          <%= link_to t("portal_self_service.registrations.log_in_cta"),
                      sign_in_path,
                      class: "block w-full text-center bg-indigo-600 text-white px-4 py-2 rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          <% if @account_access_available %>
            <%= form_with url: password_path, method: :post, local: true do |access_form| %>
              <%= access_form.hidden_field :contact, value: @account_access_contact %>
              <%= access_form.submit t("portal_self_service.registrations.send_access_link"),
                  class: "w-full bg-white text-indigo-700 border border-indigo-500 px-4 py-2 rounded-md hover:bg-indigo-50 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
            <% end %>
          <% end %>
        </div>
      </section>
    <% end %>

    <!-- Main Form -->
    <main role="main" aria-labelledby="signup-heading">
      <%= form_with model: @user,
                    url: sign_up_path,
                    local: true,
                    id: "signup-form",
                    aria: { labelledby: "signup-heading" } do |form| %>

        <%# Display base errors (not tied to a specific field) %>
        <% if @user.errors[:base].any? %>
          <div role="alert" aria-live="assertive" aria-atomic="true"
               class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
            <ul>
              <% @user.errors[:base].each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Name Fields -->
        <fieldset class="mb-4">
          <legend class="sr-only">Name</legend>
          <div class="mb-4">
            <%= form.label :first_name, "First Name", class: "block text-sm font-medium text-gray-700 mb-1 required-label" %>
            <%= form.text_field :first_name, required: true, autofocus: true,
                class: "block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 sm:text-sm",
                aria: { required: "true", invalid: @user.errors[:first_name].any?, errormessage: "first-name-error" } %>
            <% if @user.errors[:first_name].any? %>
              <p id="first-name-error" role="alert" class="mt-1 text-sm text-red-600"><%= @user.errors[:first_name].join(", ") %></p>
            <% end %>
          </div>
          <div class="mb-4">
            <%= form.label :middle_initial, "Middle Initial (Optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.text_field :middle_initial, maxlength: 1,
                class: "block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 sm:text-sm" %>
          </div>
          <div class="mb-4">
            <%= form.label :last_name, "Last Name", class: "block text-sm font-medium text-gray-700 mb-1 required-label" %>
            <%= form.text_field :last_name, required: true,
                class: "block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 sm:text-sm",
                aria: { required: "true", invalid: @user.errors[:last_name].any?, errormessage: "last-name-error" } %>
            <% if @user.errors[:last_name].any? %>
              <p id="last-name-error" role="alert" class="mt-1 text-sm text-red-600"><%= @user.errors[:last_name].join(", ") %></p>
            <% end %>
          </div>
        </fieldset>

        <!-- Contact Fields -->
        <div data-controller="optional-phone-type">
        <fieldset class="mb-4">
          <legend class="sr-only">Contact Information</legend>
          <div class="mb-4">
            <%= form.label :email, "Email Address", class: "block text-sm font-medium text-gray-700 mb-1 required-label" %>
            <%= form.email_field :email, id: "user_email", required: true, autocomplete: "email",
                class: "block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 sm:text-sm",
                aria: { required: "true", invalid: @user.errors[:email].any?, errormessage: "email-error" } %>
            <% if @user.errors[:email].any? %>
              <p id="email-error" role="alert" class="mt-1 text-sm text-red-600"><%= @user.errors[:email].join(", ") %></p>
            <% end %>
          </div>
          <div class="mb-4">
            <%= form.label :phone, "Phone Number (Optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.telephone_field :phone, pattern: "[0-9]{3}-?[0-9]{3}-?[0-9]{4}", placeholder: "202-555-5555",
                class: "block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 sm:text-sm",
                aria: { invalid: @user.errors[:phone].any?, errormessage: "phone-error", describedby: "phone-hint" },
                data: { optional_phone_type_target: "phoneInput" } %>
            <p id="phone-hint" class="text-xs text-gray-700"><%= t("portal_self_service.registrations.phone_hint") %></p>
            <% if @user.errors[:phone].any? %>
              <p id="phone-error" role="alert" class="mt-1 text-sm text-red-600"><%= @user.errors[:phone].join(", ") %></p>
            <% end %>
          </div>
          <% phone_type_describedby = ["phone-type-hint"] %>
          <% phone_type_describedby << "phone-type-error" if @user.errors[:phone_type].any? %>
          <fieldset class="mb-4 <%= 'hidden' if @user.phone.blank? %>"
                    data-optional-phone-type-target="phoneTypeFields"
                    aria-hidden="<%= @user.phone.blank? %>"
                    aria-describedby="<%= phone_type_describedby.join(' ') %>"
                    aria-invalid="<%= @user.errors[:phone_type].any? %>">
            <legend id="phone-type-legend" class="block text-sm font-medium text-gray-700 mb-1 required-label">
              <%= t("portal_self_service.registrations.phone_type_label") %>
            </legend>
            <p id="phone-type-hint" class="text-xs text-gray-700 mb-2">
              <%= t("portal_self_service.registrations.phone_type_required") %>
            </p>
            <div class="space-y-2">
              <div class="flex items-center">
                <%= form.radio_button :phone_type, "voice", id: "phone_type_voice",
                       class: "h-4 w-4 focus:ring-indigo-500",
                       disabled: @user.phone.blank?,
                       required: @user.phone.present?,
                       aria: { required: @user.phone.present?.to_s } %>
                <%= form.label :phone_type_voice, "Voice", for: "phone_type_voice", class: "ml-3 text-sm text-gray-700" %>
              </div>
              <div class="flex items-center">
                <%= form.radio_button :phone_type, "videophone", id: "phone_type_videophone",
                       class: "h-4 w-4 focus:ring-indigo-500",
                       disabled: @user.phone.blank?,
                       required: @user.phone.present?,
                       aria: { required: @user.phone.present?.to_s } %>
                <%= form.label :phone_type_videophone, "Videophone", for: "phone_type_videophone", class: "ml-3 text-sm text-gray-700" %>
              </div>
              <div class="flex items-center">
                <%= form.radio_button :phone_type, "text", id: "phone_type_text",
                       class: "h-4 w-4 focus:ring-indigo-500",
                       disabled: @user.phone.blank?,
                       required: @user.phone.present?,
                       aria: { required: @user.phone.present?.to_s } %>
                <%= form.label :phone_type_text, "Text/SMS", for: "phone_type_text", class: "ml-3 text-sm text-gray-700" %>
              </div>
            </div>
            <% if @user.errors[:phone_type].any? %>
              <p id="phone-type-error" role="alert" class="mt-1 text-sm text-red-600"><%= @user.errors[:phone_type].join(", ") %></p>
            <% end %>
          </fieldset>
        </fieldset>
        </div>

        <!-- Security Fields -->
        <fieldset class="mb-4">
          <legend class="sr-only">Security</legend>
          <div class="mb-4">
            <%= form.label :password, "Password", class: "block text-sm font-medium text-gray-700 mb-1 required-label" %>
            <div class="relative" <%= tag.attributes(data: password_visibility_data(timeout: 5000)) %>>
              <%= form.password_field :password, required: true, minlength: 6, autocomplete: "new-password",
                  class: "block w-full px-4 py-2 pr-10 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 sm:text-sm", # Added pr-10
                  :"data-visibility-target" => "field", # Add target for Stimulus
                  aria: { required: "true", invalid: @user.errors[:password].any?, errormessage: "password-error", describedby: "password-hint password-visibility-status-1" } %>
              <button type="button"
                      data-action="visibility#togglePassword"
                      class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                      aria-label="<%= t('password_visibility.toggle.show') %>"
                      aria-pressed="false">
                <svg class="h-5 w-5"
                     data-visibility-target="icon"
                     fill="none"
                     viewBox="0 0 24 24"
                     stroke="currentColor"
                     aria-hidden="true">
                  <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              </button>
              <div id="password-visibility-status-1" aria-live="polite" class="sr-only" data-visibility-target="status">
                <%= t('password_visibility.status.hidden') %>
              </div>
            </div>
            <p id="password-hint" class="text-xs text-gray-700">Minimum 6 characters</p>
            <% if @user.errors[:password].any? %>
              <p id="password-error" role="alert" class="mt-1 text-sm text-red-600"><%= @user.errors[:password].join(", ") %></p>
            <% end %>
          </div>
          <div class="mb-4">
            <%= form.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-gray-700 mb-1 required-label" %>
            <div class="relative" <%= tag.attributes(data: password_visibility_data(timeout: 5000)) %>>
              <%= form.password_field :password_confirmation, required: true, minlength: 6, autocomplete: "new-password",
                  class: "block w-full px-4 py-2 pr-10 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 sm:text-sm", # Added pr-10
                  :"data-visibility-target" => "field", # Add target for Stimulus
                  aria: { required: "true", invalid: @user.errors[:password_confirmation].any?, errormessage: "password-confirmation-error", describedby: "password-visibility-status-2" } %>
              <button type="button"
                      data-action="visibility#togglePassword"
                      class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                      aria-label="<%= t('password_visibility.toggle.show') %>"
                      aria-pressed="false">
                <svg class="h-5 w-5"
                     data-visibility-target="icon"
                     fill="none"
                     viewBox="0 0 24 24"
                     stroke="currentColor"
                     aria-hidden="true">
                  <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              </button>
              <div id="password-visibility-status-2" aria-live="polite" class="sr-only" data-visibility-target="status">
                <%= t('password_visibility.status.hidden') %>
              </div>
            </div>
            <% if @user.errors[:password_confirmation].any? %>
              <p id="password-confirmation-error" role="alert" class="mt-1 text-sm text-red-600"><%= @user.errors[:password_confirmation].join(", ") %></p>
            <% end %>
          </div>
        </fieldset>

        <!-- Date of Birth -->
        <div class="mb-4">
          <%= form.label :date_of_birth, "Date of Birth", class: "block text-sm font-medium text-gray-700 mb-1 required-label" %>
          <%= form.text_field :date_of_birth,
              required: true,
              value: accessible_date_value(@user.date_of_birth),
              placeholder: "MM/DD/YYYY",
              autocomplete: "bday",
              inputmode: "numeric",
              class: "block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 sm:text-sm",
              aria: { required: "true", invalid: @user.errors[:date_of_birth].any?, errormessage: "dob-error", describedby: "dob-hint" } %>
          <p id="dob-hint" class="text-xs text-gray-500 mt-1">Enter date of birth as MM/DD/YYYY</p>
          <% if @user.errors[:date_of_birth].any? %>
            <p id="dob-error" role="alert" class="mt-1 text-sm text-red-600"><%= @user.errors[:date_of_birth].join(", ") %></p>
          <% end %>
        </div>

        <!-- Language Preference -->
        <div class="mb-4">
          <%= form.label :locale, "Language Preference", class: "block text-sm font-medium text-gray-700 mb-1 required-label" %>
          <%= form.select :locale, [["English","en"],["Spanish","es"]], { prompt: "Select Language" },
              class: "block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 sm:text-sm",
              required: true,
              aria: { required: "true", invalid: @user.errors[:locale].any?, errormessage: "locale-error", describedby: "language-hint" } %>
          <p id="language-hint" class="text-xs text-gray-500 mt-1">Select from our supported languages</p>
          <% if @user.errors[:locale].any? %>
            <p id="locale-error" role="alert" class="mt-1 text-sm text-red-600"><%= @user.errors[:locale].join(", ") %></p>
          <% end %>
        </div>

        <!-- Notification Method -->
        <fieldset class="mb-4" data-controller="delivery-preference">
          <legend id="comm-pref-legend" class="block text-sm font-medium text-gray-700 mb-1">Notification Method</legend>
          <div class="space-y-2">
            <div class="flex items-center">
              <%= form.radio_button :communication_preference, "email", id: "pref_email", checked: true,
                     class: "h-4 w-4 focus:ring-indigo-500",
                     data: { action: "delivery-preference#togglePreference", "delivery-preference-target": "emailRadio" } %>
              <%= form.label :communication_preference_email, "Email", for: "pref_email", class: "ml-3 text-sm text-gray-700" %>
            </div>
            <div class="flex items-center">
              <%= form.radio_button :communication_preference, "letter", id: "pref_letter",
                     class: "h-4 w-4 focus:ring-indigo-500",
                     data: { action: "delivery-preference#togglePreference", "delivery-preference-target": "letterRadio" } %>
              <%= form.label :communication_preference_letter, "Mailed Letter", for: "pref_letter", class: "ml-3 text-sm text-gray-700" %>
            </div>
          </div>

          <div id="mail-notice" class="mt-2 p-3 bg-yellow-50 border border-yellow-200 rounded text-sm text-yellow-800 hidden" aria-hidden="true" data-delivery-preference-target="notice">
            <p><strong>Note:</strong> You will receive notifications by printed letter.</p>
          </div>

          <div id="address_fields" class="mt-4 hidden" aria-hidden="true" data-delivery-preference-target="addressFields">
            <div class="mb-4">
              <%= form.label :physical_address_1, "Street Address", class: "block text-sm font-medium text-gray-700 mb-1 required-label" %>
              <%= form.text_field :physical_address_1, disabled: true,
                     class: "block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <div class="mb-4">
              <%= form.label :physical_address_2, "Apt/Suite (Optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= form.text_field :physical_address_2, disabled: true,
                     class: "block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <%= form.label :city, "City", class: "block text-sm font-medium text-gray-700 mb-1 required-label" %>
                <%= form.text_field :city, disabled: true,
                       class: "block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 sm:text-sm" %>
              </div>
              <div>
                <%= form.label :state, "State", class: "block text-sm font-medium text-gray-700 mb-1 required-label" %>
                <%= form.select :state,
                    [
                      ['Alabama', 'AL'], ['Alaska', 'AK'], ['Arizona', 'AZ'], ['Arkansas', 'AR'],
                      ['California', 'CA'], ['Colorado', 'CO'], ['Connecticut', 'CT'], ['Delaware', 'DE'],
                      ['Florida', 'FL'], ['Georgia', 'GA'], ['Hawaii', 'HI'], ['Idaho', 'ID'],
                      ['Illinois', 'IL'], ['Indiana', 'IN'], ['Iowa', 'IA'], ['Kansas', 'KS'],
                      ['Kentucky', 'KY'], ['Louisiana', 'LA'], ['Maine', 'ME'], ['Maryland', 'MD'],
                      ['Massachusetts', 'MA'], ['Michigan', 'MI'], ['Minnesota', 'MN'], ['Mississippi', 'MS'],
                      ['Missouri', 'MO'], ['Montana', 'MT'], ['Nebraska', 'NE'], ['Nevada', 'NV'],
                      ['New Hampshire', 'NH'], ['New Jersey', 'NJ'], ['New Mexico', 'NM'], ['New York', 'NY'],
                      ['North Carolina', 'NC'], ['North Dakota', 'ND'], ['Ohio', 'OH'], ['Oklahoma', 'OK'],
                      ['Oregon', 'OR'], ['Pennsylvania', 'PA'], ['Rhode Island', 'RI'], ['South Carolina', 'SC'],
                      ['South Dakota', 'SD'], ['Tennessee', 'TN'], ['Texas', 'TX'], ['Utah', 'UT'],
                      ['Vermont', 'VT'], ['Virginia', 'VA'], ['Washington', 'WA'], ['West Virginia', 'WV'],
                      ['Wisconsin', 'WI'], ['Wyoming', 'WY'], ['District of Columbia', 'DC']
                    ],
                    { selected: @user.state || 'MD' },
                    { disabled: true,
                      class: "block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 sm:text-sm" } %>
              </div>
              <div>
                <%= form.label :zip_code, "Zip Code", class: "block text-sm font-medium text-gray-700 mb-1 required-label" %>
                <%= form.text_field :zip_code, disabled: true, placeholder: "12345", pattern: "[0-9]{5}(-[0-9]{4})?",
                       class: "block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 sm:text-sm" %>
              </div>
            </div>
          </div>
        </fieldset>

        <!-- Newsletter Signup -->
        <div class="mb-4">
          <div class="flex items-start">
            <%= form.check_box :newsletter_signup,
                id: "newsletter_signup",
                class: "mt-1 h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" %>
            <%= form.label :newsletter_signup,
                "Sign up for our newsletter to receive updates about MAT programs and services",
                class: "ml-2 block text-sm text-gray-700" %>
          </div>
        </div>

        <!-- Submit -->
        <div class="mb-4">
          <%= form.submit "Create Account",
              class: "w-full py-2 px-4 rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500",
              data: { disable_with: "Creating account...", "aria-busy": "true" } %>
        </div>

        <!-- Sign In -->
        <footer class="text-center">
          <p class="text-sm text-gray-700">Already have an account? <%= link_to "Sign In", sign_in_path, class: "font-medium text-indigo-600 hover:text-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500" %></p>
        </footer>

      <% end %>
    </main>
  </div>
</div>
