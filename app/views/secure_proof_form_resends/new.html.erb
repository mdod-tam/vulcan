<% content_for :title, t('.title') %>

<section class="rounded-md border border-gray-200 bg-white p-6 shadow-sm" aria-labelledby="secure-proof-resend-title">
  <h1 id="secure-proof-resend-title" class="text-2xl font-semibold text-gray-900"><%= t('.heading') %></h1>
  <p class="mt-3 text-sm text-gray-700"><%= t('.body') %></p>

  <%= form_with url: secure_proof_form_resend_path, method: :post, local: true, class: "mt-6" do |form| %>
    <%= hidden_field_tag :token, @token %>
    <%= form.submit t('.submit'),
                    class: "inline-flex w-full justify-center rounded-md bg-indigo-700 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-600 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 sm:w-auto",
                    data: { turbo_submits_with: t('.submitting') } %>
  <% end %>
</section>
